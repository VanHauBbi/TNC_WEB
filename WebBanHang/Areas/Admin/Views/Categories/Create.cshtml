@model WebBanHang.Models.Category

@{
    ViewBag.Title = "Thêm Danh Mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Tái sử dụng CSS của Products -->
<link href="~/Content/Admin/categories_admin.css" rel="stylesheet" />

<div class="claude-form-card" style="max-width: 600px; margin-top: 40px;">

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

        @* Partial View chứa các trường form và nút bấm *@
        @Html.Partial("PVCreateEditCategory", Model)
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}