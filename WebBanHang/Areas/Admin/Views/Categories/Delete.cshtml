@model WebBanHang.Models.Category

@{
    ViewBag.Title = "Xóa Danh Mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Tái sử dụng CSS của Products -->
<link href="~/Content/Admin/categories_admin.css" rel="stylesheet" />

<div class="claude-form-card" style="max-width: 600px; margin-top: 40px;">

    <div class="claude-alert-danger">
        <i class="fa-solid fa-triangle-exclamation fs-4"></i>
        <span><strong>Cảnh báo:</strong> Bạn đang chuẩn bị xóa danh mục <strong>"@Model.CategoryName"</strong>. Thao tác này không thể hoàn tác!</span>
    </div>

    @* Thông báo lỗi khi danh mục đang chứa sản phẩm không thể xóa *@
    @if (ViewBag.ConfirmDeleteMessage != null)
    {
        <div class="alert alert-danger mt-3 shadow-sm" style="border-radius: 8px;">
            <strong>⚠️ @ViewBag.ConfirmDeleteMessage</strong>
        </div>
    }

    <div class="p-4 mb-4 rounded bg-white" style="border: 1px solid var(--border-color);">
        <div class="row">
            <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">ID Danh mục:</div>
            <div class="col-8 fw-bold" style="font-family: monospace;">#@Model.CategoryID</div>
        </div>
        <hr class="my-2" style="opacity: 0.1;" />
        <div class="row">
            <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Tên Danh mục:</div>
            <div class="col-8 fw-bold" style="color: var(--text-main);">@Model.CategoryName</div>
        </div>
    </div>

    @using (Html.BeginForm("Delete", "Categories", new { id = Model.CategoryID }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <!-- Đẩy dải nút về góc phải, thêm border-top cho tách biệt -->
        <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
            <!-- Nút an toàn bên trái -->
            <a href="@Url.Action("Index", "Categories")" class="claude-btn-secondary">Hủy bỏ & Quay lại</a>

            <!-- Nút nguy hiểm bên phải ngoài cùng -->
            <button type="submit" class="claude-btn-danger">
                <i class="fa-solid fa-trash"></i> Xác nhận Xóa
            </button>
        </div>
    }
</div>