@model IEnumerable<WebBanHang.Models.Category>

@{
    ViewBag.Title = "Danh mục Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link href="~/Content/Admin/categories_admin.css" rel="stylesheet" />

<!-- ALERTS -->
@if (TempData["SuccessMessage"] != null)
{
    <div id="successMessage" class="alert alert-success alert-dismissible fade show shadow-sm" style="border-radius: 12px;">
        <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div id="errorMessage" class="alert alert-danger alert-dismissible fade show shadow-sm" style="border-radius: 12px;">
        <i class="fa-solid fa-times-circle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Ép sát khung lên trên bằng mt-0 để đồng bộ với trang Sản phẩm -->
<div class="claude-card mt-0">

    <!-- HEADER & NÚT THÊM -->
    <div class="mb-4">
        <a href="@Url.Action("Create")" class="ir-btn-add shadow-sm">
            <i class="fa-solid fa-plus"></i> Thêm Danh Mục Mới
        </a>
    </div>

    <div class="mb-3" style="padding-left: 16px;">
        <span class="text-muted" style="font-size: 0.85rem;">Tổng số: <strong>@Model.Count()</strong> danh mục.</span>
    </div>

    <!-- Đã xóa các thẻ div và table bị lặp 2 lần, ép xóa viền top -->
    <div class="table-responsive">
        <table class="claude-table table-hover mb-0">
            <thead style="border-top: none !important;">
                <tr style="border-top: none !important;">
                    <th class="text-center" style="width: 10%; border-top: none !important;">ID</th>
                    <th style="width: 60%; border-top: none !important;">TÊN DANH MỤC</th>
                    <th class="text-end" style="width: 30%; border-top: none !important;">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center text-muted" style="font-family: monospace;">#@item.CategoryID</td>
                        <td>
                            <strong style="color: var(--text-main); font-size: 1.05rem;">@item.CategoryName</strong>
                        </td>
                        <td>
                            <div class="action-cell" style="justify-content: flex-end;">
                                <a href="@Url.Action("Edit", new { id = item.CategoryID })" class="btn-action btn-edit">Edit</a>
                                <a href="@Url.Action("Delete", new { id = item.CategoryID })" class="btn-action btn-delete" title="Xóa"><i class="fa-solid fa-trash-can"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động ẩn thông báo sau 3 giây
        $(document).ready(function () {
            setTimeout(() => {
                $("#successMessage, #errorMessage").fadeOut(800);
            }, 3000);
        });
    </script>
}