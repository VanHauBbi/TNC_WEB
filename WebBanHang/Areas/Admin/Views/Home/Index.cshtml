@model WebBanHang.Models.ViewModel.AdminDashboardVM

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Tổng quan Quản trị (Dashboard)";

    // Tính toán phần trăm tỷ lệ
    double successRate = Model.TotalOrders > 0 ? Math.Round((double)Model.SuccessOrders / Model.TotalOrders * 100, 1) : 0;
    double cancelRate = Model.TotalOrders > 0 ? Math.Round((double)Model.CancelledOrders / Model.TotalOrders * 100, 1) : 0;
}

<link href="~/Content/Admin/dashboard.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row mb-4 bg-white p-3 shadow-sm rounded border align-items-end">
    <div class="col-md-4">
        <label class="fw-bold small text-muted mb-1">Từ ngày:</label>
        <input type="date" id="filterFrom" class="form-control" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")">
    </div>
    <div class="col-md-4">
        <label class="fw-bold small text-muted mb-1">Đến ngày:</label>
        <input type="date" id="filterTo" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
    </div>

    <div class="col-md-4 d-flex align-items-end gap-2">
        <button id="btnFilter" class="btn btn-primary fw-bold flex-grow-1">
            <i class="fa-solid fa-filter me-1"></i> Lọc
        </button>
        <button id="btnReset" class="btn btn-secondary fw-bold px-3">
            <i class="fa-solid fa-rotate-left"></i> Rsest
        </button>
        <button id="btnExport" class="btn btn-success fw-bold flex-grow-1">
            <i class="fa-solid fa-file-excel me-1"></i> Xuất Excel
        </button>
    </div>
</div>

<div class="container-fluid py-4">
    <h3 class="fw-bold mb-4"><i class="fa-solid fa-chart-pie text-primary"></i> Tổng quan Hệ thống</h3>
    
    <div class="row mb-4">
        <div class="col-xl col-md-4 col-sm-6 mb-3">
            <div class="card dash-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="icon-box bg-light-primary me-3" style="width:50px; height:50px; font-size:22px;"><i class="fa-solid fa-money-bill-wave"></i></div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size:0.85em;">Tổng Doanh Thu</h6>
                        <h5 id="valRevenue" class="fw-bold mb-0 text-primary">@Model.TotalRevenue.ToString("N0") ₫</h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-4 col-sm-6 mb-3">
            <div class="card dash-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="icon-box bg-light-purple me-3" style="width:50px; height:50px; font-size:22px;"><i class="fa-solid fa-piggy-bank"></i></div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size:0.85em;">Tổng Lợi Nhuận</h6>
                        <h5 id="valProfit" class="fw-bold mb-0" style="color: #6f42c1;">@Model.TotalProfit.ToString("N0") ₫</h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-4 col-sm-6 mb-3">
            <div class="card dash-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="icon-box bg-light-success me-3" style="width:50px; height:50px; font-size:22px;"><i class="fa-solid fa-box"></i></div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size:0.85em;">Tổng Đơn Hàng</h6>
                        <h5 id="valOrders" class="fw-bold mb-0">@Model.TotalOrders đơn</h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-6 col-sm-6 mb-3">
            <div class="card dash-card shadow-sm h-100">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="icon-box bg-light-warning me-3" style="width:50px; height:50px; font-size:22px;"><i class="fa-solid fa-check-circle"></i></div>
                    <div class="w-100">
                        <h6 class="text-muted mb-1" style="font-size:0.85em;">Thành công</h6>
                        <h5 class="fw-bold mb-1">@successRate %</h5>
                        <div class="progress progress-thin">
                            <div class="progress-bar bg-success" style="width: @successRate%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl col-md-6 col-sm-12 mb-3">
            <div class="card dash-card shadow-sm h-100 border-danger border-start border-4">
                <div class="card-body d-flex align-items-center p-3">
                    <div class="icon-box bg-light-danger me-3" style="width:50px; height:50px; font-size:22px;"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <div>
                        <h6 class="text-muted mb-1" style="font-size:0.85em;">Tồn kho yếu</h6>
                        <h5 class="fw-bold mb-0 text-danger">@Model.LowStockProductCount mặt hàng</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card dash-card shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-chart-line"></i> Biểu đồ Doanh thu</h5>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="100"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card dash-card shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-crown text-warning"></i> Top 5 Bán chạy nhất</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.TopSellingProducts)
                        {
                            int soldCount = item.OrderDetails.Sum(od => (int?)od.Quantity) ?? 0;
                            <li class="list-group-item d-flex align-items-center p-3">
                                <img src="@item.ProductImage" alt="img" width="50" height="50" class="me-3 table-top-product" />
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 text-truncate" style="max-width: 200px;">@item.ProductName</h6>
                                    <small class="text-danger fw-bold">@item.ProductPrice.ToString("N0") ₫</small>
                                </div>
                                <span class="badge bg-primary rounded-pill">Đã bán: @soldCount</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
<div style="display:none;">
    <table id="tableReport">
        <thead>
            <tr>
                <th>Tổng Doanh Thu</th>
                <th>Tổng Lợi Nhuận</th>
                <th>Tổng Đơn Hàng</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td id="exportRevenue">@Model.TotalRevenue.ToString("N0") ₫</td>
                <td id="exportProfit">@Model.TotalProfit.ToString("N0") ₫</td>
                <td id="exportOrders">@Model.TotalOrders</td>
            </tr>
        </tbody>
    </table>
</div>
@section Scripts {
    <script>
        // Lấy dữ liệu từ C# truyền xuống JS
        var labels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartLabels));
        var dataValues = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChartData));

        var ctx = document.getElementById('revenueChart').getContext('2d');
        var revenueChart = new Chart(ctx, {
            type: 'bar', // Có thể đổi thành 'line' nếu muốn biểu đồ đường
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: dataValues,
                    backgroundColor: 'rgba(13, 110, 253, 0.2)',
                    borderColor: 'rgba(13, 110, 253, 1)',
                    borderWidth: 2,
                    borderRadius: 5,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString('vi-VN') + ' ₫';
                            }
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return 'Doanh thu: ' + context.raw.toLocaleString('vi-VN') + ' ₫';
                            }
                        }
                    }
                }
            }
        });

    $('#btnFilter').click(function() {
        var fromDate = $('#filterFrom').val();
        var toDate = $('#filterTo').val();

        $.post('@Url.Action("GetDashboardData", "Home")', {
            fromDate: fromDate,
            toDate: toDate
        }, function (res) {
            $('#valRevenue').text(res.totalRevenue);
            $('#valProfit').text(res.totalProfit); // Phải dùng totalProfit (đúng với key trong JSON)
            $('#valOrders').text(res.orderCount + " đơn");

            // CẬP NHẬT BIỂU ĐỒ KHI LỌC
            revenueChart.data.labels = res.chartLabels;
            revenueChart.data.datasets[0].data = res.chartData;
            revenueChart.update();
        });
    });

    $('#btnReset').click(function() {
        $('#filterFrom').val('@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")');
        $('#filterTo').val('@DateTime.Now.ToString("yyyy-MM-dd")');

        $.post('@Url.Action("GetDashboardData", "Home")', {
            fromDate: '@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")',
            toDate: '@DateTime.Now.ToString("yyyy-MM-dd")'
        }, function(res) { // ĐÃ THÊM DẤU { VÀO ĐÂY
            $('#valRevenue').text(res.totalRevenue);
            $('#valProfit').text(res.totalProfit);
            $('#valOrders').text(res.orderCount + " đơn");

            revenueChart.data.labels = res.chartLabels;
            revenueChart.data.datasets[0].data = res.chartData;
            revenueChart.update();
        }); // Đóng } ở đây
    });

    $('#btnExport').click(function() {
        var uri = 'data:application/vnd.ms-excel;base64,';
        var template = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head></head><body><table>{table}</table></body></html>';
        var base64 = function(s) { return window.btoa(unescape(encodeURIComponent(s))) };
        var format = function(s, c) { return s.replace(/{(\w+)}/g, function(m, p) { return c[p]; }) };

        // Giả sử bảng chi tiết đơn hàng của bạn có id="tableReport"
        var table = document.getElementById("tableReport");
        var ctx = { worksheet: 'BaoCao', table: table.innerHTML };
        window.location.href = uri + base64(format(template, ctx));
    });
    </script>
}