@model IEnumerable<WebBanHang.Models.Customer>

@{
    ViewBag.Title = "Quản lý Khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Link tới CSS độc lập của trang Khách hàng -->
<link href="~/Content/Admin/customer_admin.css" rel="stylesheet" />

<!-- Ép sát khung lên trên bằng mt-0 -->
<div class="bd-card mt-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-muted mb-0 fs-6">Tổng cộng: <strong>@Model.Count()</strong> khách hàng trên hệ thống</p>
        </div>
    </div>

    @* ... (Khối thông báo TempData của ông để ở đây) ... *@

    <div class="table-responsive">
        <!-- Thêm mb-0 để xóa khoảng trắng thừa dưới đáy bảng -->
        <table class="bd-table mb-0">
            <!-- Ép xóa viền top dư thừa -->
            <thead style="border-top: none !important;">
                <tr style="border-top: none !important;">
                    <th style="width: 5%; border-top: none !important;">ID</th>
                    <th style="width: 20%; border-top: none !important;">KHÁCH HÀNG</th>
                    <th style="width: 20%; border-top: none !important;">TÊN ĐĂNG NHẬP</th>
                    <th style="width: 25%; border-top: none !important;">ĐỊA CHỈ</th>
                    <th style="width: 15%; border-top: none !important;" class="text-center">TRẠNG THÁI</th>
                    <th style="width: 15%; border-top: none !important;" class="text-center">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-muted">#@item.CustomerID</td>
                        <td>
                            <div class="customer-name">@item.CustomerName</div>
                            <div class="customer-email">@item.CustomerEmail</div>
                        </td>
                        <td>
                            <strong style="color: #334155;">@item.Username</strong>
                        </td>
                        <td>
                            <div class="text-truncate" style="max-width: 300px;" title="@item.CustomerAddress">
                                @(string.IsNullOrEmpty(item.CustomerAddress) ? "Chưa cập nhật" : item.CustomerAddress)
                            </div>
                        </td>
                        <td class="text-center">
                            @{
                                string statusClass = (item.IsActive == true) ? "sb-success" : "sb-danger";
                                string statusText = (item.IsActive == true) ? "Hoạt động" : "Bị khóa";
                            }
                            <span class="soft-badge @statusClass">@statusText</span>
                        </td>
                        <td class="text-center">
                            <div style="display: flex; gap: 10px; justify-content: center;">
                                <!-- Nút Chi tiết -->
                                <a href="@Url.Action("Details", new { id = item.CustomerID })" class="bd-text-btn bd-text-btn-primary text-nowrap">
                                    Chi tiết
                                </a>

                                <!-- Nút Xử lý -->
                                <a href="@Url.Action("Edit", new { id = item.CustomerID })" class="bd-text-btn bd-text-btn-outline text-nowrap">
                                    Xử lý
                                </a>
                            </div>

                            @* FORM XÓA NGAY LẬP TỨC *@
                            @*
                                @using (Html.BeginForm("Delete", "Customers", new { id = item.CustomerID }, FormMethod.Post, new { @class = "d-inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="bd-action-btn delete" title="Xóa Vĩnh Viễn"
                                            onclick="return confirm('CẢNH BÁO: Xác nhận XÓA VĨNH VIỄN khách hàng @item.CustomerName?');">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                }
                            *@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Tự động ẩn thông báo
        window.addEventListener("DOMContentLoaded", function () {
            const alertBox = document.getElementById("alertMessage");
            if (alertBox) {
                setTimeout(() => {
                    alertBox.classList.add("fade-out");
                    setTimeout(() => {
                        alertBox.remove();
                    }, 500);
                }, 3000);
            }
        });
    </script>
}