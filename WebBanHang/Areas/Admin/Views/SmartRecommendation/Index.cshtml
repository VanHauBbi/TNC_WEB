@model PagedList.IPagedList<WebBanHang.Models.SmartRecommendation>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Quản lý Gợi ý Thông minh (Hybrid AI)";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Style bắt buộc để CSS của thanh phân trang hiển thị đẹp -->
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />
<link href="~/Content/Admin/products_admin.css" rel="stylesheet" />

<style>
    /* Ép nền xám cho toàn trang */
    body, .content-wrapper, .main-content, #page-wrapper, .page-content, .container-fluid {
        background-color: #f4f6f8 !important;
    }

    /* Style cho Toast Thông báo */
    .popup-toast {
        position: fixed;
        top: 80px;
        right: 30px;
        z-index: 9999;
        min-width: 320px;
        border-radius: 8px;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    /* Tạo khoảng thở cho các dòng trong bảng */
    .table-b2b td {
        padding-top: 1rem !important;
        padding-bottom: 1rem !important;
        vertical-align: middle;
    }
</style>

<!-- KHU VỰC THÔNG BÁO POPUP -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show popup-toast bg-white border-0" role="alert" style="border-left: 5px solid #198754 !important;">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-circle-check fs-4 me-3 text-success"></i>
            <div>
                <strong class="text-dark">Thành công!</strong><br />
                <span class="small text-muted">@TempData["SuccessMessage"]</span>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show popup-toast bg-white border-0" role="alert" style="border-left: 5px solid #dc3545 !important;">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-triangle-exclamation fs-4 me-3 text-danger"></i>
            <div>
                <strong class="text-dark">Có lỗi xảy ra!</strong><br />
                <span class="small text-muted">@TempData["ErrorMessage"]</span>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mt-0 pt-3">
    <!-- KHỐI QUẢN LÝ DỮ LIỆU (Trả lại cấu trúc Card rộng rãi) -->
    <div class="card shadow-sm border-0 mb-4">

        <!-- Header -->
        <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center border-bottom">
            <div>
                <h5 class="mb-1 fw-bold text-dark">
                    <i class="fa-solid fa-microchip text-primary me-2"></i> Kết quả huấn luyện AI
                </h5>
                <p class="text-muted mb-0" style="font-size: 0.85rem;">Danh sách các luật kết hợp (Apriori + Two-Phase)</p>
            </div>

            @using (Html.BeginForm("RunAlgorithm", "SmartRecommendation", FormMethod.Post, new { @class = "d-inline m-0", id = "runAlgorithmForm" }))
            {
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-warning fw-bold shadow-sm px-4 text-nowrap" style="border-radius: 6px; color: #fff;" onclick="confirmRunAlgorithm()">
                    <i class="fa-solid fa-rotate me-2"></i> Ép quét lại toàn bộ (Thủ công)
                </button>
            }
        </div>

        <!-- Body (Tạo khoảng đệm rộng rãi cho bảng) -->
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover table-b2b mb-0 border-bottom">
                    <thead class="table-light text-muted" style="font-size: 0.9rem;">
                        <tr>
                            <th style="width: 25%;" class="ps-3">Khách xem (A)</th>
                            <th style="width: 25%;"><i class="fa-solid fa-arrow-right text-success me-2"></i> Sẽ gợi ý mua kèm (B)</th>
                            <th class="text-center">Tin cậy</th>
                            <th class="text-center">Tần suất</th>
                            <th class="text-center">TWU</th>
                            <th class="text-center text-success">Lợi nhuận 1 Combo</th>
                            <th class="text-center pe-3">Cập nhật</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <!-- SẢN PHẨM A -->
                                    <td class="ps-3">
                                        <a href="@Url.Action("ProductAIDetails", "SmartRecommendation", new { area = "Admin", id = item.Product.ProductID })" class="text-decoration-none d-flex align-items-center" title="Xem chi tiết thuật toán">
                                            <img src="@item.Product.ProductImage" alt="Ảnh A" style="width: 55px; height: 55px; object-fit: contain; border-radius: 6px;" class="me-3 border bg-white p-1 shadow-sm" />
                                            <span class="fw-bold text-primary" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: 0.95rem;">
                                                @item.Product.ProductName
                                            </span>
                                        </a>
                                    </td>

                                    <!-- SẢN PHẨM B -->
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@item.Product1.ProductImage" alt="Ảnh B" style="width: 55px; height: 55px; object-fit: contain; border-radius: 6px;" class="me-3 border bg-white p-1 shadow-sm" />
                                            <span class="fw-bold text-dark" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: 0.95rem;">
                                                @item.Product1.ProductName
                                            </span>
                                        </div>
                                    </td>

                                    <!-- TIN CẬY (Sửa lại màu chuẩn SaaS Pastel) -->
                                    <td class="text-center">
                                        @{
                                            var confPercent = item.Confidence * 100;
                                            string badgeStyle = "";

                                            // Tùy chỉnh màu nền nhạt, chữ đậm chuẩn UI/UX
                                            if (confPercent >= 60)
                                            {
                                                badgeStyle = "background-color: #e6f4ea; color: #137333; border: 1px solid #ceead6;"; // Xanh lá
                                            }
                                            else if (confPercent >= 30)
                                            {
                                                badgeStyle = "background-color: #fef7e0; color: #b06000; border: 1px solid #fbdc8e;"; // Cam/Vàng
                                            }
                                            else
                                            {
                                                badgeStyle = "background-color: #fce8e6; color: #c5221f; border: 1px solid #fad2cf;"; // Đỏ
                                            }
                                        }
                                        <span class="badge rounded-pill px-3 py-2 shadow-sm" style="@badgeStyle font-size: 0.85rem;">
                                            @confPercent.ToString("0.##")%
                                        </span>
                                    </td>

                                    <!-- TẦN SUẤT -->
                                    <td class="text-center">
                                        <span class="fw-bold text-danger fs-6">@item.Support</span> <span class="text-muted small">lần</span>
                                    </td>

                                    <!-- TWU -->
                                    <td class="text-end text-muted" style="font-size: 0.9rem;">
                                        @item.TWU.ToString("N0") đ
                                    </td>

                                    <!-- LỢI NHUẬN COMBO -->
                                    <td class="text-center">
                                        <span class="fw-bold text-success fs-6">
                                            + @item.ActualUtility.ToString("N0") ₫
                                        </span>
                                    </td>

                                    <!-- CẬP NHẬT -->
                                    <td class="text-center pe-3">
                                        <div class="text-muted" style="font-size: 0.85rem;">
                                            <div class="fw-medium text-dark">@item.UpdateDate.ToString("dd/MM/yyyy")</div>
                                            <div style="font-size: 0.8rem;">@item.UpdateDate.ToString("HH:mm")</div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7">
                                    <div class="d-flex flex-column align-items-center justify-content-center text-muted py-5">
                                        <i class="fa-solid fa-robot fs-1 mb-3" style="color: #cbd5e1;"></i>
                                        <h6 class="fw-bold text-dark">Chưa có dữ liệu nào được khai phá</h6>
                                        <span style="font-size: 0.9rem;">Hệ thống sẽ <b>tự động học</b> khi khách hàng bắt đầu đặt các đơn hàng.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- ALERT THÔNG TIN TỐI ƯU -->
            <div class="bg-white rounded shadow-sm border-0 mt-4 mb-4 p-3 d-flex align-items-center" style="border-left: 4px solid #0dcaf0 !important;">
                <i class="fa-solid fa-graduation-cap fs-2 text-info me-3"></i>
                <div style="font-size: 0.95rem;">
                    <strong class="text-dark">Sự tối ưu (Hybrid AI):</strong> Hệ thống lai áp dụng <b>Apriori</b> để đảm bảo tính liên kết (Không gợi ý bừa bãi), và <b>Two-Phase</b> để tối đa hóa <b>Lợi nhuận Combo</b>. Hệ thống luôn ưu tiên hiển thị cặp sản phẩm mang lại biên lợi nhuận lớn nhất!
                </div>
            </div>
            <!-- PHÂN TRANG -->
            <div class="d-flex justify-content-center mt-4">
                @if (Model != null && Model.PageCount > 1)
                {
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), PagedListRenderOptions.ClassicPlusFirstAndLast)
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function confirmRunAlgorithm() {
            if (confirm('Hệ thống hiện đã TỰ ĐỘNG học mỗi khi có đơn hàng mới.\n\nBạn có chắc chắn vẫn muốn ÉP hệ thống quét lại toàn bộ ngay bây giờ?')) {
                var btn = $('#runAlgorithmForm button');
                btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Đang huấn luyện AI...');
                document.getElementById('runAlgorithmForm').submit();
            }
        }

        $(document).ready(function () {
            if ($(".popup-toast").length > 0) {
                setTimeout(function () {
                    $(".popup-toast").fadeOut("slow", function () {
                        $(this).remove();
                    });
                }, 5000);
            }
        });
    </script>
}