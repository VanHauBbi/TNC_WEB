@using PagedList.Mvc
@model PagedList.IPagedList<WebBanHang.Models.Product>

<link href="~/Content/Admin/products_admin.css" rel="stylesheet" />

@if (Model != null && Model.Any())
{
    <table class="table table-bordered table-hover table-admin-data">
        <thead class="table-dark">
            <tr>
                <th style="width: 8%;">Ảnh</th>
                <th style="width: 25%;">Tên sản phẩm</th>
                <th style="width: 12%;" class="text-end">Giá bán</th>
                <th style="width: 12%;" class="text-end">Giá nhập</th>
                <th style="width: 10%;" class="text-center">Tồn kho</th>
                <th style="width: 13%;">Danh mục</th>
                <th style="width: 20%;" class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@Html.DisplayFor(modelItem => item.ProductImage)" alt="@item.ProductName" class="product-thumb-admin" />
                    </td>
                    <td>
                        <strong class="text-primary">@Html.DisplayFor(modelItem => item.ProductName)</strong>
                    </td>
                    <td class="text-end fw-bold text-danger">
                        @item.ProductPrice.ToString("N0") ₫
                    </td>
                    <td class="text-end fw-bold text-success">
                        @item.ImportPrice.ToString("N0") ₫
                    </td>
                    <td class="text-center">
                        @if (item.StockQuantity > 0)
                        {
                            <span class="badge bg-success" style="font-size: 0.9em;">@item.StockQuantity</span>
                        }
                        else
                        {
                            <span class="badge bg-danger" style="font-size: 0.9em;">Hết hàng</span>
                        }
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Category.CategoryName)
                    </td>
                    <td class="text-center">
                        @Html.ActionLink("Sửa", "Edit", new { id = item.ProductID }, new { @class = "btn btn-warning btn-sm me-1" })
                        @Html.ActionLink("Chi tiết", "Details", new { id = item.ProductID }, new { @class = "btn btn-info btn-sm me-1" })
                        @Html.ActionLink("Xóa", "Delete", new { id = item.ProductID }, new { @class = "btn btn-danger btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning text-center mt-3">
        Không tìm thấy sản phẩm nào phù hợp với bộ lọc.
    </div>
}