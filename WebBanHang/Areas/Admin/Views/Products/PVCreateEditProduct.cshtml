@model WebBanHang.Models.Product

<div class="form-group">
    <div class="control-label col-md-2 fw-bold">Danh mục</div>
    <div class="col-md-10">
        @* DropDownList phải được truyền CategoryID từ Controller *@
        @Html.DropDownList("CategoryID", null, "--- Chọn Danh mục ---", htmlAttributes: new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.CategoryID, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    <div class="control-label col-md-2 fw-bold">Tên sản phẩm</div>
    <div class="col-md-10">
        @Html.EditorFor(model => model.ProductName, new { htmlAttributes = new { @class = "form-control" } })
        @Html.ValidationMessageFor(model => model.ProductName, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    <div class="control-label col-md-2 fw-bold">Mô tả</div>
    <div class="col-md-10">
        @Html.TextAreaFor(model => model.ProductDescription, new { @class = "form-control", rows = 4 })
        @Html.ValidationMessageFor(model => model.ProductDescription, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    <div class="control-label col-md-2 fw-bold">Giá bán (Đơn giá)</div>
    <div class="col-md-10">
        @* KHẮC PHỤC LỖI HIỂN THỊ SỐ: Dùng TextBoxFor và ép định dạng InvariantCulture *@
        @Html.TextBoxFor(model => model.ProductPrice, new
        {
            @class = "form-control",
            type = "number",
            min = "0",
            @Value = Model != null ? Model.ProductPrice.ToString("0", System.Globalization.CultureInfo.InvariantCulture) : ""
        })
        @Html.ValidationMessageFor(model => model.ProductPrice, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    <div class="control-label col-md-2 fw-bold">Giá nhập kho</div>
    <div class="col-md-10">
        @* KHẮC PHỤC LỖI HIỂN THỊ SỐ: Dùng TextBoxFor và ép định dạng InvariantCulture *@
        @Html.TextBoxFor(model => model.ImportPrice, new
        {
            @class = "form-control",
            type = "number",
            min = "0",
            @Value = Model != null ? Model.ImportPrice.ToString("0", System.Globalization.CultureInfo.InvariantCulture) : ""
        })
        @Html.ValidationMessageFor(model => model.ImportPrice, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    <div class="control-label col-md-2 fw-bold">Hình ảnh (URL)</div>
    <div class="col-md-10">
        @Html.EditorFor(model => model.ProductImage, new { htmlAttributes = new { @class = "form-control" } })
        @Html.ValidationMessageFor(model => model.ProductImage, "", new { @class = "text-danger" })
    </div>
</div>

<div class="form-group">
    <div class="control-label col-md-2 fw-bold">Số lượng tồn kho</div>
    <div class="col-md-10">
        @* Số lượng là số nguyên nên giữ nguyên EditorFor nhưng bổ sung value an toàn nếu cần *@
        @Html.EditorFor(model => model.StockQuantity, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
        @Html.ValidationMessageFor(model => model.StockQuantity, "", new { @class = "text-danger" })
    </div>
</div>