@model WebBanHang.Models.Product

@{
    bool isCreateMode = (Model == null || Model.ProductID == 0);
}

<div class="row mb-3">
    <div class="col-md-6">
        <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
        @Html.DropDownList("CategoryID", null, "--- Chọn Danh mục ---", htmlAttributes: new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.CategoryID, "", new { @class = "text-danger" })
    </div>
    <div class="col-md-6">
        <label class="form-label fw-bold">Nhãn Build PC (Phân loại)</label>
        <select name="ComponentType" class="form-control">
            <option value="" @(Model?.ComponentType == "" ? "selected" : "")>-- Không phân loại / PC Nguyên bộ --</option>
            <option value="CPU" @(Model?.ComponentType == "CPU" ? "selected" : "")>CPU - Vi xử lý</option>
            <option value="RAM" @(Model?.ComponentType == "RAM" ? "selected" : "")>RAM - Bộ nhớ trong</option>
            <option value="VGA" @(Model?.ComponentType == "VGA" ? "selected" : "")>VGA - Card màn hình</option>
            <option value="MAIN" @(Model?.ComponentType == "MAIN" ? "selected" : "")>Mainboard - Bo mạch chủ</option>
            <option value="SSD" @(Model?.ComponentType == "SSD" ? "selected" : "")>Ổ cứng SSD/HDD</option>
            <option value="PSU" @(Model?.ComponentType == "PSU" ? "selected" : "")>PSU - Nguồn máy tính</option>
            <option value="CASE" @(Model?.ComponentType == "CASE" ? "selected" : "")>Case - Vỏ máy tính</option>
            <option value="MONITOR" @(Model?.ComponentType == "MONITOR" ? "selected" : "")>Màn hình</option>
            <option value="GEAR" @(Model?.ComponentType == "GEAR" ? "selected" : "")>Phụ kiện (Gear)</option>
        </select>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-7">
        <label class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
        @Html.EditorFor(model => model.ProductName, new { htmlAttributes = new { @class = "form-control", id = "txtProductName" } })
        @Html.ValidationMessageFor(model => model.ProductName, "", new { @class = "text-danger" })
    </div>
    <div class="col-md-5">
        <label class="form-label fw-bold">Mã SKU & Đối soát API</label>
        <div class="input-group">
            @Html.EditorFor(model => model.SKU, new { htmlAttributes = new { @class = "form-control bg-light fw-bold text-primary", id = "txtSKU", @readonly = "readonly" } })
            @if (isCreateMode)
            {
                <button class="btn btn-warning fw-bold" type="button" id="btnGetSKU" title="Sinh mã SKU từ tên">Tạo SKU</button>
            }
            <button class="btn btn-info fw-bold text-white" type="button" id="btnScrapePrice" title="Tra cứu giá gốc từ GitHub">
                <i class="fa-solid fa-cloud-arrow-down"></i> Cào Giá
            </button>
        </div>
        <small id="scrapeMsg" class="fw-bold mt-1 d-block"></small>
    </div>
</div>

<div class="mb-3">
    <label class="form-label fw-bold">Mô tả sản phẩm</label>
    @Html.TextAreaFor(model => model.ProductDescription, new { @class = "form-control", rows = 3 })
</div>

<div class="row mb-4 p-3 bg-light rounded border">
    <div class="col-md-4">
        <label class="form-label fw-bold text-primary">Giá bán niêm yết (₫)</label>
        @Html.TextBoxFor(model => model.ProductPrice, new
        {
            @class = "form-control fw-bold text-primary fs-5",
            type = "number",
            min = "0",
            id = "ProductPrice",
            @Value = Model != null ? Model.ProductPrice.ToString("0") : "0"
        })
        <small class="text-muted">Nhập '0' nếu là hàng mới chưa chốt giá bán ra</small>
    </div>
    <div class="col-md-8">
        <label class="form-label fw-bold">Hình ảnh (URL)</label>
        @Html.EditorFor(model => model.ProductImage, new { htmlAttributes = new { @class = "form-control" } })
    </div>
</div>

@if (!isCreateMode)
{
    <hr class="my-3" />
    <div class="row mb-3 bg-white p-3 border rounded">
        <div class="col-md-4">
            <label class="form-label fw-bold">Trạng thái kinh doanh</label>
            <select name="Status" class="form-control fw-bold">
                <option value="0" @(Model?.Status == 0 ? "selected" : "")>0: Bản nháp (Chờ hàng về)</option>
                <option value="1" @(Model?.Status == 1 ? "selected" : "")>1: Đang kinh doanh</option>
                <option value="2" @(Model?.Status == 2 ? "selected" : "")>2: Tạm hết hàng</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label fw-bold">Tồn kho thực tế (FIFO)</label>
            @Html.EditorFor(model => model.StockQuantity, new { htmlAttributes = new { @class = "form-control bg-light fw-bold text-success", @readonly = "readonly" } })
        </div>
        <div class="col-md-4">
            <label class="form-label fw-bold">Giá Vốn Kế Toán</label>
            @Html.EditorFor(model => model.ImportPrice, new { htmlAttributes = new { @class = "form-control bg-light fw-bold text-danger", @readonly = "readonly", @Value = Model != null ? Model.ImportPrice.ToString("0") : "0" } })
        </div>
    </div>
}