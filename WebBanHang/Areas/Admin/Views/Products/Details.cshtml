@model WebBanHang.Models.Product

@{
    ViewBag.Title = "Chi tiết Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link href="~/Content/Admin/products_admin.css" rel="stylesheet" />

<div class="claude-form-card">

    @Html.Partial("PVProdInfo", Model)

    <!-- Nút hành động đặt ở góc phải dưới cùng -->
    <div class="mt-4 pt-3 d-flex justify-content-end gap-2">
        <a href="javascript:history.back()" class="claude-btn-secondary">Quay lại</a>

        <button type="submit" class="btn-claude-primary px-4">
            <i class="fa-solid fa-check"></i> Cập nhật thay đổi
        </button>
    </div>
</div>