@model WebBanHang.Models.Product

@{
    ViewBag.Title = "Thêm Sản Phẩm Mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link href="@Url.Content("~/Content/Admin/products_admin.css")" rel="stylesheet" />

<div class="claude-form-card">
    <h4 class="claude-form-title">@ViewBag.Title</h4>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

        @Html.Partial("PVCreateEditProduct", Model)

        <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
            @Html.ActionLink("Quay lại", "Index", null, new { @class = "claude-btn-secondary" })
            <button type="submit" class="btn-claude-primary px-4"><i class="fa-solid fa-plus"></i> Lưu sản phẩm</button>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <!-- Giữ nguyên toàn bộ đoạn script Javascript của ông ở đây -->
    <script>
        $(document).ready(function () {
            // 1. NÚT TẠO SKU NỘI BỘ
            $('#btnGetSKU').click(function () {
                var name = $('#txtProductName').val();
                if (!name) { alert("Vui lòng nhập Tên sản phẩm trước!"); return; }
                $.get('@Url.Action("GenerateSKUPreview", "Products")', { productName: name }, function (res) {
                    if (res.success) { $('#txtSKU').val(res.sku); }
                    else { alert(res.message); }
                });
            });

            // 2. NÚT CÀO GIÁ TỪ GITHUB
            $('#btnScrapePrice').click(function () {
                var sku = $('#txtSKU').val();
                var msgBox = $('#scrapeMsg');
                if (!sku) {
                    alert("Vui lòng gõ hoặc bấm 'Tạo SKU' trước khi cào dữ liệu đối tác!");
                    return;
                }
                msgBox.text("Đang kết nối API GitHub...").removeClass("text-danger text-success").addClass("text-primary");
                $.get('/Admin/ImportReceipts/FetchSupplierPrice', { sku: sku }, function (res) {
                    if (res.success) {
                        msgBox.text("💡 Giá nhập đối tác: " + res.price.toLocaleString('vi-VN') + " đ").removeClass("text-primary").addClass("text-success");
                        var curPrice = parseFloat($('#ProductPrice').val()) || 0;
                        if (curPrice === 0) {
                            var suggestedSelling = res.price * 1.2;
                            $('#ProductPrice').val(suggestedSelling);
                            alert("Đã cào được giá gốc: " + res.price.toLocaleString('vi-VN') + " đ.\n\n💡 Hệ thống tạm điền gợi ý Giá Bán (đã cộng 20% lời) là: " + suggestedSelling.toLocaleString('vi-VN') + " đ.\nBạn có thể tự chỉnh lại con số này tùy ý!");
                        }
                    } else {
                        msgBox.text("Không tìm thấy SKU này trên API đối tác.").removeClass("text-primary").addClass("text-danger");
                    }
                });
            });
        });
    </script>
}