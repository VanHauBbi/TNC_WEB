@model WebBanHang.Models.Order

@{
    ViewBag.Title = "Chi tiết Đơn hàng #" + Model.OrderID;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    // Tính toán tiền
    decimal subTotal = Model.OrderDetails?.Sum(d => d.UnitPrice * d.Quantity) ?? 0;
    decimal shippingFee = Model.TotalAmount - subTotal;
    if (shippingFee < 0) { shippingFee = 0; }

    string paymentStatus = Model.PaymentStatus ?? "Chưa thanh toán";
    string paymentBadge = "sb-warning";
    if (paymentStatus == "Đã thanh toán") { paymentBadge = "sb-success"; }
    else if (paymentStatus == "Thất bại") { paymentBadge = "sb-danger"; }

    string orderStatus = Model.OrderStatus ?? "Chưa xử lý";
    string displayStatus = string.IsNullOrEmpty(Model.OrderStatus) ? "Chờ xác nhận" : Model.OrderStatus;
    string orderBadge = "sb-neutral";

    if (orderStatus == "Đã duyệt - Đang lấy hàng" || orderStatus == "Đang giao") { orderBadge = "sb-info"; }
    else if (orderStatus == "Đã duyệt" || orderStatus == "Đã giao") { orderBadge = "sb-success"; }
    else if (orderStatus == "Đã hủy") { orderBadge = "sb-danger"; }
}


<link href="~/Content/Admin/order_admin.css?v=2" rel="stylesheet" />

<div class="row mt-0 pt-0">
    <!-- CỘT TRÁI -->
    <div class="col-lg-8">

        <!-- Khối Sản phẩm -->
        <div class="bd-card mb-4">
            <div class="d-flex align-items-center mb-2 gap-2">
                <span class="fw-bold fs-6">Đơn hàng #@Model.OrderID</span>
                <span class="soft-badge @paymentBadge">@Model.PaymentStatus</span>
                <span class="soft-badge @orderBadge">@displayStatus</span>
            </div>
            <div class="text-muted mb-4 small">
                Ngày đặt: @Model.OrderDate.ToString("dd/MM/yyyy 'lúc' HH:mm")
            </div>
            <h6 class="fw-bold mb-3">Sản phẩm</h6>
            @if (Model.OrderDetails != null)
            {
                foreach (var detail in Model.OrderDetails)
                {
                    <div class="bd-product-row border-bottom-0 pb-0 mb-2 mt-2">
                        <img src="@detail.Product.ProductImage" class="bd-product-img" alt="Product" />
                        <div class="bd-product-info">
                            <div class="bd-product-name">@detail.Product.ProductName</div>
                            <div class="bd-product-meta text-muted">@detail.UnitPrice.ToString("N0") ₫</div>
                        </div>
                        <div class="bd-product-qty">x @detail.Quantity</div>
                        <div class="bd-product-price fw-bold text-dark">@String.Format("{0:N0} ₫", detail.UnitPrice * detail.Quantity)</div>
                    </div>
                }
            }
        </div>

        <!-- Khối Thanh toán -->
        <div class="bd-card mb-4">
            <h6 class="fw-bold mb-3">Thanh toán</h6>
            <div class="bd-summary-row mb-2">
                <span class="text-muted">Tiền hàng (@(Model.OrderDetails?.Count() ?? 0) sản phẩm)</span>
                <span>@subTotal.ToString("N0") ₫</span>
            </div>
            <div class="bd-summary-row mb-3">
                <span class="text-muted">Phí vận chuyển (@Model.ShippingMethod)</span>
                <span>+@shippingFee.ToString("N0") ₫</span>
            </div>
            <div class="bd-summary-row total pt-3 border-top mb-3">
                <span class="fw-bold fs-5">Tổng cộng</span>
                <span class="text-danger fw-bold fs-5">@Model.TotalAmount.ToString("N0") ₫</span>
            </div>
            <div class="d-flex justify-content-between pt-3 border-top">
                <span class="text-muted fw-bold">Phương thức thanh toán</span>
                <span class="fw-bold text-dark">@Model.PaymentMethod</span>
            </div>
        </div>

        <!-- Nút Quay lại đã được khoác CSS và dời xuống dưới cùng -->
        @{
            // Lấy lại URL chứa số trang (page=2), nếu Session null thì trả về Index mặc định
            string backUrl = Session["LastOrderListUrl"] as string ?? Url.Action("Index", "Orders");
        }

        <div class="mb-5">
            <a href="@backUrl" class="bd-btn bd-btn-outline">
                <i class="fa-solid fa-angle-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>

    <!-- CỘT PHẢI -->
    <div class="col-lg-4">
        <div class="bd-card">
            <!-- Tăng kích thước chữ tiêu đề lên fs-5 -->
            <h6 class="fw-bold mb-2 fs-5">Khách hàng</h6>

            <!-- Tên khách hàng -->
            <div class="text-dark mb-4 fs-6">@Model.Customer.CustomerName</div>

            <!-- Khối Thông tin liên hệ (Đã xóa các class 'small') -->
            <div class="text-muted fw-bold mb-2">Thông tin liên hệ</div>

            <div class="fw-bold text-dark">Số điện thoại</div>
            <div class="text-muted mb-3">@Model.Customer.CustomerPhone</div>

            <div class="fw-bold text-dark">Email</div>
            <div class="text-muted mb-3">@(string.IsNullOrEmpty(Model.Customer.CustomerEmail) ? "Không có" : Model.Customer.CustomerEmail)</div>

            <!-- Khối Địa chỉ giao hàng (Đã xóa class 'small') -->
            <div class="fw-bold text-dark">Địa chỉ giao hàng</div>
            <div class="text-muted"> @Model.ShippingAddress <br /> Việt Nam </div>
        </div>
    </div>
</div>