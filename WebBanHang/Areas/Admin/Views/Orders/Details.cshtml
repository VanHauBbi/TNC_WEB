@model WebBanHang.Models.Order

@{
    ViewBag.Title = "Chi tiết Đơn hàng #" + Model.OrderID;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-header bg-white border-bottom pb-0">
                <h5 class="fw-bold text-primary"><i class="fa-solid fa-file-invoice"></i> Thông tin Giao dịch #@Model.OrderID</h5>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-sm-4">
                        <p class="mb-1 text-muted small">Khách hàng</p>
                        <h6 class="fw-bold">@Model.Customer.CustomerName</h6>
                        <p class="mb-0 small"><i class="fa-solid fa-phone"></i> @Model.Customer.CustomerPhone</p>
                    </div>
                    <div class="col-sm-4">
                        <p class="mb-1 text-muted small">Ngày đặt hàng</p>
                        <h6 class="fw-bold">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</h6>
                        <p class="mb-0 small"><i class="fa-solid fa-location-dot"></i> @Model.ShippingAddress</p>
                    </div>
                    <div class="col-sm-4">
                        <p class="mb-1 text-muted small">Trạng thái duyệt</p>
                        @{
                            string statusBadge = "bg-secondary"; // Mặc định là Chờ duyệt
                            if (Model.OrderStatus != null)
                            {
                                if (Model.OrderStatus.Contains("Đã duyệt")) { statusBadge = "bg-info text-dark"; }
                                else if (Model.OrderStatus.Contains("Đang giao")) { statusBadge = "bg-warning text-dark"; }
                                else if (Model.OrderStatus.Contains("Đã giao")) { statusBadge = "bg-success"; }
                                else if (Model.OrderStatus.Contains("hủy")) { statusBadge = "bg-danger"; }
                            }
                        }
                        <h6 class="mb-0"><span class="badge @statusBadge px-3 py-2 fs-6">@Model.OrderStatus</span></h6>
                    </div>
                </div>

                <div class="row mb-4 p-3 bg-light rounded">
                    <div class="col-sm-6">
                        <p class="mb-1 text-muted small">Phương thức Thanh toán</p>
                        <h6 class="fw-bold text-dark mb-2">@Model.PaymentMethod</h6>
                        @{
                            string payClass = Model.PaymentStatus == "Đã thanh toán" ? "bg-success" : "bg-warning text-dark";
                        }
                        <span class="badge @payClass">@Model.PaymentStatus</span>
                    </div>
                    <div class="col-sm-6">
                        <p class="mb-1 text-muted small">Đơn vị Vận chuyển</p>
                        <h6 class="fw-bold text-dark">@Model.ShippingMethod</h6>
                    </div>
                </div>

                <h6 class="fw-bold mb-3 border-bottom pb-2">Danh sách Sản phẩm đã đặt</h6>
                <div class="table-responsive">
                    <table class="table table-borderless align-middle">
                        <thead class="table-light text-muted small">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.OrderDetails != null)
                            {
                                foreach (var detail in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@detail.Product.ProductImage" width="40" height="40" class="rounded me-2" style="object-fit:cover;" />
                                                <span class="fw-bold small" style="max-width: 350px; display: block;">@detail.Product.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="text-center text-danger small">@detail.UnitPrice.ToString("N0") ₫</td>
                                        <td class="text-center small">@detail.Quantity</td>
                                        <td class="text-end fw-bold text-danger">@String.Format("{0:N0} ₫", detail.UnitPrice * detail.Quantity)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="border-top">
                            @{
                                // 1. Tính tổng tiền các sản phẩm dựa trên chi tiết đơn
                                decimal subTotal = 0;
                                if (Model.OrderDetails != null)
                                {
                                    subTotal = Model.OrderDetails.Sum(d => d.UnitPrice * d.Quantity);
                                }

                                // 2. Tính toán phí vận chuyển thực tế từ độ chênh lệch
                                decimal realShippingFee = Model.TotalAmount - subTotal;
                                if (realShippingFee < 0) { realShippingFee = 0; }
                            }

                            <tr>
                                <td colspan="3" class="text-end text-muted small pt-3 pb-1">Tiền hàng:</td>
                                <td class="text-end fw-bold pt-3 pb-1">@subTotal.ToString("N0") ₫</td>
                            </tr>

                            <tr>
                                <td colspan="3" class="text-end text-muted small py-1">
                                    Phí bưu điện (GHN):
                                </td>
                                <td class="text-end fw-bold text-success py-1">
                                    @(realShippingFee > 0 ? "+" + realShippingFee.ToString("N0") + " ₫" : "Miễn phí")
                                </td>
                            </tr>

                            <tr class="border-top">
                                <td colspan="3" class="text-end text-dark small pt-3"><strong>TỔNG THANH TOÁN:</strong></td>
                                <td class="text-end fw-bold text-danger fs-5 pt-3">@Model.TotalAmount.ToString("N0") ₫</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="mt-4 border-top pt-3">
                    <a href="@Url.Action("Index", "Orders")" class="btn btn-secondary px-4"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách</a>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-primary text-white">
                    <strong><i class="fa fa-truck"></i> Cập nhật tiến độ giao hàng</strong>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("UpdateOrderStatus", "Orders", new { area = "Admin" }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model.OrderID" />

                        <div class="input-group">
                            <select name="newStatus" class="form-control">
                                <option value="Chờ duyệt" @(Model.OrderStatus == "Chờ duyệt" ? "selected" : "")>1. Chờ duyệt (Mới đặt)</option>
                                <option value="Đã duyệt - Đang lấy hàng" @(Model.OrderStatus == "Đã duyệt - Đang lấy hàng" ? "selected" : "")>2. Đã duyệt - Đang lấy hàng</option>
                                <option value="Đang giao hàng" @(Model.OrderStatus == "Đang giao hàng" ? "selected" : "")>3. Đang giao hàng</option>
                                <option value="Đã giao hàng" @(Model.OrderStatus == "Đã giao hàng" ? "selected" : "")>4. Đã giao hàng (Hoàn thành)</option>
                                <option value="Đã hủy" @(Model.OrderStatus == "Đã hủy" ? "selected" : "")>Đơn đã hủy</option>
                            </select>
                            <button type="submit" class="btn btn-warning fw-bold">Cập nhật ngay</button>
                        </div>
                    }
                </div>
            </div>

            <a href="@Url.Action("Tracking", "Orders", new { id = Model.OrderID })" class="btn btn-warning fw-bold text-white">
                <i class="fa-solid fa-location-dot"></i> THEO DÕI ĐƠN HÀNG
            </a>

        </div>
    </div>
</div>