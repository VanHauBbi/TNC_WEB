@model WebBanHang.Models.Order

@{
    ViewBag.Title = "Xử lý Đơn hàng #" + Model.OrderID;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    // Tính toán tiền
    decimal subTotal = Model.OrderDetails?.Sum(d => d.UnitPrice * d.Quantity) ?? 0;
    decimal shippingFee = Model.TotalAmount - subTotal;
    if (shippingFee < 0) { shippingFee = 0; }
    decimal discountAmount = 0;

    string paymentStatus = Model.PaymentStatus ?? "Chưa thanh toán";
    string paymentBadge = "sb-warning";
    if (paymentStatus == "Đã thanh toán") { paymentBadge = "sb-success"; }
    else if (paymentStatus == "Thất bại") { paymentBadge = "sb-danger"; }

    string orderStatus = Model.OrderStatus ?? "Chưa xử lý";
    string displayStatus = string.IsNullOrEmpty(Model.OrderStatus) ? "Chờ xác nhận" : Model.OrderStatus;
    string orderBadge = "sb-neutral";

    if (orderStatus == "Đã duyệt - Đang lấy hàng" || orderStatus == "Đang giao") { orderBadge = "sb-info"; }
    else if (orderStatus == "Đã duyệt" || orderStatus == "Đã giao") { orderBadge = "sb-success"; }
    else if (orderStatus == "Đã hủy") { orderBadge = "sb-danger"; }
}

<!-- Đã bỏ cái đuôi ?v=... đi, trả về đúng đường dẫn chuẩn của hệ thống -->
<link href="~/Content/Admin/order_admin.css" rel="stylesheet" />

<div class="row mt-0 pt-0">
    <!-- CỘT TRÁI -->
    <div class="col-lg-8">
        <div class="bd-card">

            <div class="d-flex justify-content-between align-items-center pb-3 border-bottom mb-3">
                <h5 class="text-primary fw-bold mb-0 fs-4">RTV-@Model.OrderID</h5>
            </div>

            <div>
                @if (Model.OrderDetails != null)
                {
                    foreach (var detail in Model.OrderDetails)
                    {
                        <div class="bd-product-row">
                            <img src="@detail.Product.ProductImage" class="bd-product-img" alt="Product" />
                            <div class="bd-product-info">
                                <div class="bd-product-name">@detail.Product.ProductName</div>
                                <div class="bd-product-meta">SKU: SP-@detail.ProductID</div>
                            </div>
                            <div class="bd-product-qty">@detail.UnitPrice.ToString("N0")₫ x @detail.Quantity</div>
                            <div class="bd-product-price">@String.Format("{0:N0}₫", detail.UnitPrice * detail.Quantity)</div>
                        </div>
                    }
                }
            </div>

            <div class="row mt-4 pt-4 border-top">
                <div class="col-md-6">
                    <div class="bd-customer-box">
                        <div class="bd-avatar"><i class="fa-solid fa-user"></i></div>
                        <div>
                            <div class="fw-bold text-dark fs-6">@Model.Customer.CustomerName</div>
                            <div class="text-muted">@(string.IsNullOrEmpty(Model.Customer.CustomerEmail) ? "Không có email" : Model.Customer.CustomerEmail)</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="bd-summary-row">
                        <span>Tạm tính</span>
                        <span>@subTotal.ToString("N0") ₫</span>
                    </div>
                    <div class="bd-summary-row">
                        <span>Phí vận chuyển</span>
                        <span>(+) @shippingFee.ToString("N0") ₫</span>
                    </div>
                    @if (discountAmount > 0)
                    {
                        <div class="bd-summary-row text-success">
                            <span>Giảm giá</span>
                            <span>(-) @discountAmount.ToString("N0") ₫</span>
                        </div>
                    }
                    <div class="bd-summary-row total">
                        <span>Tổng cộng</span>
                        <span>@Model.TotalAmount.ToString("N0") ₫</span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4 pt-3 border-top gap-2">
                @using (Html.BeginForm("Process", "Orders", new { id = Model.OrderID }, FormMethod.Post, new { @class = "d-flex gap-2 flex-wrap justify-content-end" }))
                {
                    @Html.AntiForgeryToken()

                    if (Model.PaymentStatus == "Thất bại" || Model.PaymentStatus == "Đã hủy" || Model.OrderStatus == "Đã hủy")
                    {
                        <span class="text-danger fw-bold mt-2"><i class="fa-solid fa-ban"></i> Đơn hàng đã bị vô hiệu hóa.</span>
                    }
                    else
                    {
                        if (string.IsNullOrEmpty(Model.OrderStatus) || Model.OrderStatus == "Chờ xác nhận")
                        {
                            <button type="submit" name="actionType" value="Cancel" class="bd-btn bd-btn-danger" onclick="return confirm('Hủy đơn hàng này?')">Hủy đơn</button>
                            <button type="submit" name="actionType" value="Approve" class="bd-btn bd-btn-primary">Duyệt đơn hàng</button>
                        }
                        else if (Model.OrderStatus == "Đã duyệt")
                        {
                            <button type="submit" name="actionType" value="Ship" class="bd-btn bd-btn-primary">Bắt đầu giao hàng</button>
                        }
                        else if (Model.OrderStatus == "Đang giao")
                        {
                            <button type="submit" name="actionType" value="Complete" class="bd-btn bd-btn-success" onclick="return confirm('Xác nhận đã giao hàng?')">Hoàn thành đơn</button>
                        }

                        if (Model.PaymentStatus != "Đã thanh toán")
                        {
                            <button type="submit" name="actionType" value="MarkPaid" class="bd-btn bd-btn-outline" onclick="return confirm('Xác nhận thu tiền?')"><i class="fa-solid fa-money-bill"></i> Thu tiền</button>
                        }
                    }
                }
            </div>
        </div>

        <!-- Nút Quay lại đã được dời xuống dưới cùng -->
        @{
            // Lấy lại URL chứa số trang (page=2), nếu Session null thì trả về Index mặc định
            string backUrl = Session["LastOrderListUrl"] as string ?? Url.Action("Index", "Orders");
        }

        <div class="mb-5">
            <a href="@backUrl" class="bd-btn bd-btn-outline">
                <i class="fa-solid fa-angle-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>

    <!-- CỘT PHẢI -->
    <div class="col-lg-4">
        <div class="bd-card">
            <div class="bd-detail-row">
                <span class="bd-detail-label">Ngày đặt</span>
                <span class="bd-detail-value">@Model.OrderDate.ToString("dd MMM yyyy")</span>
            </div>
            <div class="bd-detail-row">
                <span class="bd-detail-label">Thanh toán</span>
                <span class="bd-detail-value">
                    <i class="fa-solid fa-money-bill-1-wave me-1 text-muted"></i> @Model.PaymentMethod
                </span>
            </div>
            <div class="bd-detail-row">
                <span class="bd-detail-label">Người nhận</span>
                <span class="bd-detail-value">@Model.Customer.CustomerName<br /><span class="fw-normal text-muted">@Model.Customer.CustomerPhone</span></span>
            </div>
            <div class="bd-detail-row">
                <span class="bd-detail-label">Địa chỉ giao</span>
                <span class="bd-detail-value fw-normal" style="line-height: 1.5;">
                    @Model.ShippingAddress <br /> Việt Nam
                </span>
            </div>
            <div class="bd-detail-row">
                <span class="bd-detail-label">ĐV vận chuyển</span>
                <span class="bd-detail-value">@Model.ShippingMethod</span>
            </div>
            <div class="bd-detail-row">
                <span class="bd-detail-label">Thanh toán</span>
                <span class="bd-detail-value">
                    <span class="soft-badge @paymentBadge">@Model.PaymentStatus</span>
                </span>
            </div>
            <div class="bd-detail-row">
                <span class="bd-detail-label">Trạng thái</span>
                <span class="bd-detail-value">
                    <span class="soft-badge @orderBadge">@displayStatus</span>
                </span>
            </div>
        </div>
    </div>
</div>