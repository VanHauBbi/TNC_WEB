@model WebBanHang.Models.ImportReceipt

@{
    ViewBag.Title = "Chi tiết Phiếu Nhập #" + Model.ReceiptID;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white pb-0 border-bottom">
        <h5 class="fw-bold text-primary"><i class="fa-solid fa-file-lines"></i> Phiếu Nhập Kho #@Model.ReceiptID</h5>
    </div>
    <div class="card-body">
        <div class="row mb-4 p-3 bg-light rounded">
            <div class="col-sm-4">
                <p class="mb-1 text-muted small">Ngày thực hiện</p>
                <h6 class="fw-bold">@Model.ReceivedDate.ToString("dd/MM/yyyy HH:mm")</h6>
            </div>
            <div class="col-sm-4">
                <p class="mb-1 text-muted small">Người thực hiện</p>
                <h6 class="fw-bold">@Model.ReceivedBy</h6>
            </div>
            <div class="col-sm-4">
                <p class="mb-1 text-muted small">Ghi chú</p>
                <h6 class="fw-bold">@Model.Note</h6>
            </div>
        </div>

        <h6 class="fw-bold mb-3 border-bottom pb-2">Danh sách Lô hàng (Cơ sở FIFO)</h6>
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lượng nhập</th>
                        <th class="text-center text-success">Còn tồn trong lô</th>
                        <th class="text-end">Giá Nhập Cố Định</th>
                        <th class="text-end">Thành tiền Lô</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.ImportReceiptDetails)
                    {
                        <tr>
                            <td class="fw-bold">@detail.Product.ProductName</td>
                            <td class="text-center">@detail.ImportQuantity</td>
                            <td class="text-center fw-bold text-success">@detail.RemainingQuantity</td>
                            <td class="text-end text-danger">@detail.ImportPrice.ToString("N0") ₫</td>
                            <td class="text-end fw-bold text-danger">@((detail.ImportPrice * detail.ImportQuantity).ToString("N0")) ₫</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="bg-light">
                        <td colspan="4" class="text-end fw-bold">TỔNG GIÁ TRỊ PHIẾU:</td>
                        <td class="text-end fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0") ₫</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <a href="@Url.Action("Index")" class="btn btn-secondary mt-3"><i class="fa-solid fa-arrow-left"></i> Quay lại lịch sử</a>
    </div>
</div>