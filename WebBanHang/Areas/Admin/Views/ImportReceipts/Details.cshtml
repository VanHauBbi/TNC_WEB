@model WebBanHang.Models.ImportReceipt

@{
    ViewBag.Title = "Chi tiết Phiếu Nhập #" + Model.ReceiptID;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link href="~/Content/Admin/import_receipt_admin.css" rel="stylesheet" />

<div class="card detail-card mb-4 bg-white">
    <div class="card-header bg-white pb-3 pt-3 border-bottom d-flex justify-content-between align-items-center">
        <h5 class="fw-bold text-primary mb-0">
            <i class="fa-solid fa-file-lines me-2"></i> Phiếu Nhập Kho #@Model.ReceiptID
        </h5>
    </div>

    <div class="card-body p-4">
        <!-- Khối thông tin chung -->
        <div class="row mb-4 p-3 bg-light rounded" style="border: 1px dashed #e2e8f0;">
            <div class="col-sm-4">
                <p class="mb-1 text-muted small text-uppercase fw-bold">Ngày thực hiện</p>
                <h6 class="fw-bold text-dark mb-0 fs-6">@Model.ReceivedDate.ToString("dd/MM/yyyy HH:mm")</h6>
            </div>
            <div class="col-sm-4">
                <p class="mb-1 text-muted small text-uppercase fw-bold">Người thực hiện</p>
                <h6 class="fw-bold text-dark mb-0 fs-6">@Model.ReceivedBy</h6>
            </div>
            <div class="col-sm-4">
                <p class="mb-1 text-muted small text-uppercase fw-bold">Ghi chú</p>
                <h6 class="fw-bold text-secondary mb-0 fs-6">@(string.IsNullOrEmpty(Model.Note) ? "Không có ghi chú" : Model.Note)</h6>
            </div>
        </div>

        <h6 class="fw-bold mb-3 pb-2 text-dark">Danh sách Lô hàng (Cơ sở FIFO)</h6>

        <!-- Bảng chi tiết -->
        <div class="table-responsive border rounded mb-4">
            <table class="table detail-table align-middle">
                <thead>
                    <tr>
                        <!-- Chia tỷ lệ: Cột sản phẩm 40%, các cột còn lại mỗi cột 15% -->
                        <th class="ps-4" style="width: 40%;">Sản phẩm</th>
                        <th class="text-center text-nowrap" style="width: 15%;">Số lượng nhập</th>
                        <th class="text-center text-success text-nowrap" style="width: 15%;">Còn tồn trong lô</th>
                        <th class="text-end text-nowrap" style="width: 15%;">Giá Nhập Cố Định</th>
                        <th class="text-end pe-4 text-nowrap" style="width: 15%;">Thành tiền Lô</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.ImportReceiptDetails)
                    {
                        <tr>
                            <td class="fw-bold text-dark ps-4">@detail.Product.ProductName</td>
                            <td class="text-center">@detail.ImportQuantity</td>
                            <td class="text-center fw-bold text-success">@detail.RemainingQuantity</td>
                            <!-- Thêm text-nowrap để giá tiền và chữ "đ" dính chặt vào nhau -->
                            <td class="text-end text-danger fw-medium text-nowrap">@detail.ImportPrice.ToString("N0") ₫</td>
                            <td class="text-end fw-bold text-danger pe-4 text-nowrap">@((detail.ImportPrice * detail.ImportQuantity).ToString("N0")) ₫</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="4" class="text-end fw-bold text-dark text-uppercase" style="font-size: 0.9rem;">Tổng giá trị phiếu:</td>
                        <!-- text-nowrap bảo vệ tổng tiền cuối cùng -->
                        <td class="text-end fw-bold text-danger fs-5 pe-4 text-nowrap">@Model.TotalAmount.ToString("N0") ₫</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Nút Quay lại thiết kế mới -->
        <a href="@Url.Action("Index")" class="btn-back-pastel">
            <i class="fa-solid fa-arrow-left-long me-2"></i> Quay lại lịch sử
        </a>
    </div>
</div>