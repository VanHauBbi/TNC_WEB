@model IEnumerable<WebBanHang.Models.ImportReceipt>

@{
    ViewBag.Title = "Lịch sử Nhập Kho (P.O)";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<link href="~/Content/Admin/import_receipt_admin.css" rel="stylesheet" />
<div class="mt-0 pt-0">
    <!-- KHỐI QUẢN LÝ PHIẾU NHẬP -->
    <div class="ir-wrapper">

        <!-- Header -->
        <div class="ir-header d-flex justify-content-between align-items-center">

            <i class="text-muted mb-0" style="font-size: 1.20rem;">Quản lý và tra cứu các chứng từ nhập hàng (P.O)</i>

            <a href="@Url.Action("Create")" class="ir-btn-add shadow-sm">
                <i class="fa-solid fa-plus me-2"></i> Lập Phiếu Nhập
            </a>
        </div>

        <!-- Bảng Dữ Liệu -->
        <div class="table-responsive">
            <table class="ir-table text-start">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 12%;">Mã Phiếu</th>
                        <th style="width: 20%;">Người Nhập</th>
                        <th style="width: 18%;">Ngày Nhập</th>
                        <th style="width: 15%;">Ghi Chú</th>
                        <th class="text-center" style="width: 25%;">Tổng Tiền (Giá Vốn)</th>
                        <th class="text-center pe-4" style="width: 10%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="d-flex flex-column align-items-center justify-content-center text-muted">
                                    <i class="fa-solid fa-box-open fs-1 mb-3" style="color: #cbd5e1;"></i>
                                    <span class="fw-medium" style="font-size: 0.95rem;">Chưa có chứng từ nhập kho nào.</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                <tr>
                    <!-- Mã Phiếu -->
                    <td class="ps-4">
                        <strong class="fw-bold text-dark">#@item.ReceiptID</strong>
                    </td>

                    <!-- Người Nhập -->
                    <td>
                        <div class="fw-medium text-dark">@item.ReceivedBy</div>
                    </td>

                    <!-- Ngày Nhập -->
                    <td>
                        <div class="fw-bold text-dark" style="font-size: 0.95rem;">
                            @item.ReceivedDate.ToString("dd/MM/yyyy")
                        </div>
                        <div class="text-muted" style="font-size: 0.85rem;">
                            <i class="fa-regular fa-clock me-1"></i>@item.ReceivedDate.ToString("HH:mm")
                        </div>
                    </td>

                    <!-- Ghi Chú -->
                    <td>
                        <div class="text-secondary" style="font-size: 0.9rem;">
                            @(string.IsNullOrWhiteSpace(item.Note) ? "-" : item.Note)
                        </div>
                    </td>

                    <!-- Tổng Tiền -->
                    <td class="text-center fw-bold text-danger">
                        @item.TotalAmount.ToString("N0") ₫
                    </td>

                    <!-- Thao tác -->
                    <td class="text-center pe-4">
                        <a href="@Url.Action("Details", new { id = item.ReceiptID })" class="ir-btn-detail">
                            Chi tiết
                        </a>
                    </td>
                </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>