@{
    // Lấy tên Controller hiện tại từ RouteData
    string currentController = ViewContext.RouteData.Values["controller"].ToString();

    // Hàm Helper để kiểm tra và trả về class 'active'
    string GetActiveClass(string controllerName)
    {
        return controllerName.Equals(currentController, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị - @ViewBag.Title</title>

    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link href="~/Content/Admin/home_admin.css" rel="stylesheet" />

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar expanded" id="sidebar">
        <!-- Toggle Button -->
        <button class="toggle-sidebar-btn" id="toggleSidebarBtn" type="button" title="Thu/Mở Sidebar">
            <i class="fa-solid fa-bars"></i>
        </button>

        <!-- Logo -->
        <div class="admin-logo-box">
            <img src="~/TopIcon/logo-tnc.png" alt="Admin Logo" />
        </div>

        <!-- Menu - SCROLLABLE -->
        <ul class="sidebar-menu" id="sidebarMenu">
            <li>
                <a href="@Url.Action("Index", "Home")" class="@GetActiveClass("Home")" data-tooltip="Dashboard">
                    <i class="fa-solid fa-tachometer-alt"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Products")" class="@GetActiveClass("Products")" data-tooltip="Sản phẩm">
                    <i class="fa-solid fa-box-open"></i>
                    <span>Quản lý Sản phẩm</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Categories")" class="@GetActiveClass("Categories")" data-tooltip="Danh mục">
                    <i class="fa-solid fa-sitemap"></i>
                    <span>Quản lý Danh mục</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Orders")" class="@GetActiveClass("Orders")" data-tooltip="Đơn hàng">
                    <i class="fa-solid fa-receipt"></i>
                    <span>Quản lý Đơn hàng</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Customers")" class="@GetActiveClass("Customers")" data-tooltip="Khách hàng">
                    <i class="fa-solid fa-users"></i>
                    <span>Quản lý Khách hàng</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Coupons")" class="@GetActiveClass("Coupons")" data-tooltip="Mã giảm giá">
                    <i class="fa-solid fa-ticket"></i>
                    <span>Quản lý Mã Giảm Giá</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "PriceHistory")" class="@GetActiveClass("PriceHistory")" data-tooltip="Lịch sử">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <span>Truy xuất lịch sử</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "ImportReceipts", new { area = "Admin" })" class="@GetActiveClass("ImportReceipts")" data-tooltip="Nhập kho">
                    <i class="fa-solid fa-truck-loading"></i>
                    <span>Nhập Kho FIFO</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "AdminSupport")" class="@GetActiveClass("AdminSupport")" data-tooltip="Hỗ trợ">
                    <i class="fa-solid fa-headset"></i>
                    <span>Hỗ Trợ Khách Hàng</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Recommendations", new { area = "Admin" })" class="@GetActiveClass("Recommendations")" data-tooltip="AI">
                    <i class="fa-solid fa-brain"></i>
                    <span>Huấn luyện AI (Apriori)</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Logout", "Account", new { Area = "" })" data-tooltip="Đăng xuất">
                    <i class="fa-solid fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </a>
            </li>
        </ul>
    </div>

    <div class="main-content">

        <div class="admin-header">
            <h1 class="admin-title">@ViewBag.Title</h1>
            <div class="admin-user-info">
                <span class="text-secondary">Xin chào, @Session["UserName"]</span>
            </div>
        </div>

        <div class="container-fluid">
            @RenderBody()
        </div>

        <div class="admin-footer-copyright">
            <p>&copy; @DateTime.Now.Year - Khu vực Quản trị Hệ thống</p>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <script>
        $(document).ready(function () {
            $("#toggleSidebarBtn").on("click", function (e) {
                e.preventDefault();
                $("#sidebar").toggleClass("expanded collapsed");
                $(".main-content").toggleClass("expanded collapsed");
            });
        });
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>