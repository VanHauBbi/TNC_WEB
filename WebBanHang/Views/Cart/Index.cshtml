@model WebBanHang.Models.ViewModel.Cart

@{
    ViewBag.Title = "Giỏ hàng";
    Layout = "~/Views/Shared/_LayoutDivMain.cshtml";
}

<link rel="stylesheet" href="~/Content/myStyle/cart.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<h2 class="cart-title">🛒 Giỏ hàng của bạn</h2>

<div class="shopping-cart-page container">
    @if (!Model.Items.Any())
    {
        <div class="empty-cart-container">
            <div class="empty-cart-box">
                <i class="fa-solid fa-cart-shopping empty-icon"></i>
                <h3 class="empty-title">Giỏ hàng của bạn đang trống!</h3>
                <p class="empty-message">Dường như bạn chưa thêm sản phẩm nào vào giỏ. Hãy trở lại trang chủ để khám phá các ưu đãi và lấp đầy giỏ hàng nhé.</p>
                @Html.ActionLink("TIẾP TỤC MUA SẮM", "Index", "Home", null, new { @class = "btn-continue-shopping large-btn" })
            </div>
        </div>
    }
    else
    {
        <div class="continue-shopping-btn-container">
            @Html.ActionLink("← TIẾP TỤC MUA HÀNG", "Index", "Home", null, new { @class = "btn-continue-shopping-inline" })
        </div>

        <div class="cart-content-wrapper">
            <div class="cart-items-list">
                @foreach (var item in Model.Items)
                {
                    <div class="cart-item-card">
                        <input type="checkbox" class="item-select-checkbox"
                               value="@item.ProductID"
                               data-original-price="@item.OriginalPrice"
                               data-unit-price="@item.UnitPrice"
                               data-discountable-qty="@item.DiscountableQuantity"
                               checked onchange="calculateCartTotal()" />

                        <div class="cart-item-left">
                            <img src="@item.ProductImage" alt="@item.ProductName" class="cart-product-img" />
                            <div class="cart-item-info">
                                <h5 class="cart-item-name">@item.ProductName</h5>

                                @if (item.OriginalPrice > item.UnitPrice)
                                {
                                    <div class="cart-item-price mb-2">
                                        <span class="text-muted text-decoration-line-through me-2" style="font-size: 0.85em;">@item.OriginalPrice.ToString("N0") ₫</span>
                                        <span class="text-danger fw-bold">@item.UnitPrice.ToString("N0") ₫</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="cart-item-price mb-2 text-danger fw-bold">@item.UnitPrice.ToString("N0") ₫</div>
                                }

                                @* HIỂN THỊ TỒN KHO *@
                                <div class="small text-muted mb-2">
                                    <i class="fa-solid fa-warehouse"></i> Còn lại:
                                    @if (item.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success text-white fw-bold">@item.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger text-white fw-bold">Hết hàng</span>
                                    }
                                </div>

                                @* CẢNH BÁO KHI CHỌN QUÁ TỒN KHO *@
                                @if (item.Quantity > item.StockQuantity)
                                {
                                    <div class="alert alert-danger p-2 small mb-2" style="font-size: 12px; border-radius: 4px;">
                                        <i class="fa-solid fa-triangle-exclamation"></i> Vượt quá tồn kho thực tế! (Tối đa: @item.StockQuantity)
                                    </div>
                                }

                                <div class="quantity-control-custom">
                                    <button type="button" class="btn-qty-control minus-btn"
                                            onclick="cartUpdateQuantity(@item.ProductID, @item.Quantity - 1, @item.StockQuantity)">
                                        <i class="fa-solid fa-minus"></i>
                                    </button>
                                    <input type="number" value="@item.Quantity" min="1" max="@item.StockQuantity" readonly class="quantity-box-custom" />
                                    <button type="button" class="btn-qty-control plus-btn"
                                            onclick="cartUpdateQuantity(@item.ProductID, @item.Quantity + 1, @item.StockQuantity)">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="cart-item-right">
                            <p class="item-total">@item.TotalPrice.ToString("N0") VNĐ</p>
                            <button type="button" class="btn-remove-item" onclick="cartRemoveItem(@item.ProductID)">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="cart-summary-box">
                <h4 class="summary-title">Tóm tắt đơn hàng</h4>
                <div class="summary-details">
                    <p><span>Sản phẩm chọn:</span> <span id="summary-total-items" style="font-weight: 700;">0</span></p>
                    <p><span>Tạm tính:</span> <span id="summary-subtotal-value">0 VNĐ</span></p>

                    <p id="summary-discount-row" class="text-success" style="display: none; justify-content: space-between;">
                        <span>Giảm giá sản phẩm:</span>
                        <span id="summary-discount-value" class="fw-bold">-0 VNĐ</span>
                    </p>

                    <div class="summary-divider"></div>
                    <p class="summary-total"><strong>Tổng thanh toán:</strong> <strong id="summary-total-value">0 VNĐ</strong></p>
                </div>

                @{
                    bool hasInvalidQuantity = Model.Items.Any(i => i.Quantity > i.StockQuantity);
                }

                @if (hasInvalidQuantity)
                {
                    <button class="btn-checkout-final w-100 mt-3" disabled style="background-color: #6c757d; cursor: not-allowed; border: none;">
                        GIẢM SỐ LƯỢNG ĐỂ THANH TOÁN
                    </button>
                }
                else
                {
                    <button type="button" class="btn-checkout-final w-100 mt-3" style="border: none; cursor: pointer;" onclick="proceedToCheckout()">
                        TIẾN HÀNH THANH TOÁN
                    </button>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Cập nhật số lượng có kiểm tra tồn kho bằng JS
        function cartUpdateQuantity(id, newQuantity, stockLimit) {
            if (newQuantity < 1) return;
            if (newQuantity > stockLimit) {
                alert("⚠️ Không thể tăng thêm số lượng! Hiện tại kho chỉ còn " + stockLimit + " sản phẩm.");
                return;
            }

            const form = document.createElement('form');
            form.method = 'post';
            form.action = '@Url.Action("UpdateQuantity", "Cart")';

            const idInput = document.createElement('input'); idInput.type = 'hidden'; idInput.name = 'id'; idInput.value = id;
            const qtyInput = document.createElement('input'); qtyInput.type = 'hidden'; qtyInput.name = 'quantity'; qtyInput.value = newQuantity;

            form.appendChild(idInput); form.appendChild(qtyInput);
            document.body.appendChild(form); form.submit();
        }

        function cartRemoveItem(id) {
            if (confirm("Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?")) {
                window.location.href = '@Url.Action("RemoveFromCart", "Cart")' + '?id=' + id;
            }
        }

        function calculateCartTotal() {
            var checkboxes = document.getElementsByClassName('item-select-checkbox');
            var totalItems = 0;
            var subtotalValue = 0; // Tổng tiền tính theo giá gốc
            var actualTotalValue = 0; // Tổng tiền thực tế sau khi áp dụng luật giới hạn

            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].checked) {
                    var row = checkboxes[i].closest('.cart-item-card');
                    var originalPrice = parseFloat(checkboxes[i].getAttribute('data-original-price'));
                    var unitPrice = parseFloat(checkboxes[i].getAttribute('data-unit-price'));
                    var discountableQty = parseInt(checkboxes[i].getAttribute('data-discountable-qty'));
                    var qty = parseInt(row.querySelector('.quantity-box-custom').value);

                    totalItems += qty;

                    // THUẬT TOÁN TÁCH DÒNG (Min-Bounding) TẠI CLIENT
                    var applicableQty = Math.min(qty, discountableQty);
                    var remainingQty = qty - applicableQty;

                    // Cộng dồn tổng nguyên giá
                    subtotalValue += (qty * originalPrice);

                    // Cộng dồn tổng thực tế (Sản phẩm có slot voucher * giá giảm + Sản phẩm hết slot * giá gốc)
                    actualTotalValue += (applicableQty * unitPrice) + (remainingQty * originalPrice);
                }
            }

            var totalDiscount = subtotalValue - actualTotalValue;

            // In dữ liệu ra màn hình
            document.getElementById('summary-total-items').innerText = totalItems;
            document.getElementById('summary-subtotal-value').innerText = subtotalValue.toLocaleString('vi-VN') + ' VNĐ';
            document.getElementById('summary-total-value').innerText = actualTotalValue.toLocaleString('vi-VN') + ' VNĐ';

            // Ẩn/Hiện dòng Giảm giá
            var discountRow = document.getElementById('summary-discount-row');
            if (totalDiscount > 0) {
                document.getElementById('summary-discount-value').innerText = '-' + totalDiscount.toLocaleString('vi-VN') + ' VNĐ';
                discountRow.style.display = 'flex'; // Dùng flex để giữ 2 thẻ span nằm ở 2 bên trái/phải
            } else {
                discountRow.style.display = 'none';
            }
        }

        function proceedToCheckout() {
            var checkboxes = document.getElementsByClassName('item-select-checkbox');
            var selectedIds = [];

            for (var i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].checked) {
                    selectedIds.push(parseInt(checkboxes[i].value));
                }
            }

            if (selectedIds.length === 0) {
                alert("Vui lòng chọn ít nhất 1 sản phẩm để thanh toán.");
                return;
            }

            $.ajax({
                url: '@Url.Action("ProceedToCheckout", "Cart")',
                type: 'POST',
                data: { selectedIds: selectedIds },
                success: function(res) {
                    if (res.success) window.location.href = res.redirectUrl;
                    else alert(res.message);
                },
                error: function() { alert("Lỗi kết nối. Vui lòng thử lại."); }
            });
        }

        $(document).ready(function() {
            calculateCartTotal();
        });
    </script>
}