@model WebBanHang.Models.ViewModel.CheckoutVM
@{
    ViewBag.Title = "Đặt hàng";
    Layout = "~/Views/Shared/_LayoutDivMain.cshtml";
}

<link rel="stylesheet" href="~/Content/myStyle/checkout.css" />

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<div class="checkout-page-container container">
    <h2 class="page-title text-center">💳 ĐẶT HÀNG</h2>

    @using (Html.BeginForm("Checkout", "Orders", FormMethod.Post, new { @class = "checkout-form", role = "form", onsubmit = "return validateAndPrepareSubmit();" }))
    {
        @Html.AntiForgeryToken()

        <input type="hidden" name="isBuyNow" value="@(ViewBag.IsBuyNow != null && (bool)ViewBag.IsBuyNow ? "true" : "false")" />

        <div class="row">
            <div class="col-md-7 checkout-left-col">

                <div class="checkout-section shipping-section">
                    <h3 class="section-title">1. Địa chỉ và Vận chuyển</h3>

                    <div class="form-group-custom mb-3">
                        <label class="control-label fw-bold">Tỉnh / Thành phố <span class="text-danger">*</span></label>
                        <select id="ddlProvince" class="form-control custom-input" required>
                            <option value="">-- Chọn Tỉnh / Thành phố --</option>
                        </select>
                    </div>
                    <div class="form-group-custom mb-3">
                        <label class="control-label fw-bold">Quận / Huyện <span class="text-danger">*</span></label>
                        <select id="ddlDistrict" class="form-control custom-input" required disabled>
                            <option value="">-- Chọn Quận / Huyện --</option>
                        </select>
                    </div>
                    <div class="form-group-custom mb-3">
                        <label class="control-label fw-bold">Phường / Xã <span class="text-danger">*</span></label>
                        <select id="ddlWard" class="form-control custom-input" required disabled>
                            <option value="">-- Chọn Phường / Xã --</option>
                        </select>
                    </div>
                    <div class="form-group-custom mb-3">
                        <label class="control-label fw-bold">Số nhà, tên đường cụ thể <span class="text-danger">*</span></label>
                        <input type="text" id="txtStreetAddress" class="form-control custom-input" placeholder="Ví dụ: 123 Nguyễn Trãi" required />
                    </div>

                    @Html.HiddenFor(m => m.ShippingAddress, new { @id = "shippingAddress" })

                    <input type="hidden" id="hdnProvinceId" name="GHNProvinceId" />
                    <input type="hidden" id="hdnDistrictId" name="GHNDistrictId" />
                    <input type="hidden" id="hdnWardCode" name="GHNWardCode" />
                    <input type="hidden" id="HiddenShippingFee" name="ShippingFee" value="0" />
                    <div class="shipping-options-group mt-4">
                        <h4 class="option-group-title">Phương thức giao hàng</h4>
                        <div class="radio-option">
                            @Html.RadioButtonFor(m => m.ShippingMethod, "Giao Hàng Nhanh (GHN)", new { @id = "ship-ghn", @checked = "checked" })
                            <label for="ship-ghn">Giao Hàng Nhanh (GHN) - Phí: <strong class="text-danger" id="shippingFeeLabel">Chưa xác định</strong></label>
                        </div>
                        @Html.ValidationMessageFor(m => m.ShippingMethod, null, new { @class = "text-danger" })
                    </div>

                    <div class="payment-options-group mt-4">
                        <h4 class="option-group-title">Phương thức thanh toán</h4>
                        <div class="radio-option">
                            @Html.RadioButtonFor(m => m.PaymentMethod, "Tiền mặt", new { @id = "pay-cash" })
                            <label for="pay-cash">Thanh toán khi nhận hàng (COD)</label>
                        </div>
                        <div class="radio-option">
                            <label>
                                <input type="radio" name="PaymentMethod" value="VNPAY" />
                                <i class="fa fa-credit-card text-primary"></i> Thanh toán qua cổng VNPAY
                            </label>
                        </div>
                        @Html.ValidationMessageFor(m => m.PaymentMethod, null, new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="col-md-5 checkout-right-col">
                <div class="summary-box-checkout">
                    <h3 class="section-title">2. Thông tin đơn hàng</h3>
                    <div class="order-item-list">
                        <table class="order-summary-table">
                            <thead>
                                <tr>
                                    <th class="product-col">Sản phẩm</th>
                                    <th class="qty-col">SL</th>
                                    <th class="price-col">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    decimal totalOriginalAmount = 0;
                                }
                                @foreach (var item in Model.CartItems)
                                {
                                    totalOriginalAmount += (item.OriginalPrice * item.Quantity);
                                    <tr class="order-item-row">
                                        <td>
                                            <!-- Dòng ẩn chứa ID sản phẩm để cảm biến quét -->
                                            <input type="hidden" class="cart-item-id" value="@item.ProductID" />

                                            <img src="@item.ProductImage" alt="@item.ProductName" class="item-thumb" />
                                            <span class="item-name-summary">@item.ProductName</span>
                                        </td>
                                        <td class="item-qty-summary">@item.Quantity</td>
                                        <td class="price-text">
                                            @if (item.OriginalPrice > item.UnitPrice)
                                            {
                                                <div class="text-muted text-decoration-line-through" style="font-size: 0.85em;">@((item.OriginalPrice * item.Quantity).ToString("N0")) ₫</div>
                                            }
                                            <div class="text-danger fw-bold">@item.TotalPrice.ToString("N0") VNĐ</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="voucher-section mt-3 mb-3 p-3 bg-white border border-info rounded shadow-sm">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <label class="fw-bold mb-1"><i class="fa-solid fa-ticket text-primary"></i> TNC Voucher</label>
                                    <div id="selectedVoucherDisplay" class="text-muted small">Chưa chọn mã nào</div>
                                </div>
                                <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#voucherModal">
                                    Thay đổi
                                </button>
                            </div>
                            <div id="voucherMessage" class="mt-2 small" style="display:none;"></div>

                            @Html.HiddenFor(m => m.AppliedVoucherCode, new { @id = "AppliedVoucherCode" })
                            <input type="hidden" name="VoucherDiscount" id="VoucherDiscount" value="0" />
                        </div>
                    </div>

                    <div class="total-calculation-area">
                        @{
                            decimal totalProductDiscount = totalOriginalAmount - Model.TotalAmount;
                        }

                        <div class="calc-row">
                            <span>Tạm tính (@Model.CartItems.Sum(i => i.Quantity) sản phẩm):</span>
                            <span class="price-value">@totalOriginalAmount.ToString("N0") VNĐ</span>
                        </div>

                        @if (totalProductDiscount > 0)
                        {
                            <div class="calc-row text-success">
                                <span>Giảm giá sản phẩm:</span>
                                <span class="price-value fw-bold">-@totalProductDiscount.ToString("N0") VNĐ</span>
                            </div>
                        }

                        <div class="calc-row">
                            <span>Phí vận chuyển (GHN):</span>
                            <span class="price-value shipping-fee text-info" id="shippingFeeDisplay">Chờ tính phí...</span>
                        </div>

                        <div class="calc-row text-danger" id="voucherRow" style="display: none;">
                            <span>Giảm giá Voucher:</span>
                            <span class="price-value fw-bold" id="voucherDiscountDisplay">-0 VNĐ</span>
                        </div>

                        <div class="calc-row final-total-row mt-3 border-top pt-3">
                            <strong>Tổng thanh toán:</strong>
                            <strong class="total-price-final text-danger fs-4" id="finalTotalDisplay">@Model.TotalAmount.ToString("N0") VNĐ</strong>
                            @Html.HiddenFor(m => m.TotalAmount, new { @id = "TotalAmount" })
                        </div>
                    </div>

                    <div class="place-order-action">
                        <input type="submit" value="HOÀN TẤT ĐẶT HÀNG" class="btn-place-order track-buy" />
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="voucherModal" tabindex="-1" aria-labelledby="voucherModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title text-primary fw-bold" id="voucherModalLabel"><i class="fa-solid fa-tags"></i> Chọn TNC Voucher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-light">
                @if (Model.AvailableCoupons != null && Model.AvailableCoupons.Any())
                {
                    foreach (var coupon in Model.AvailableCoupons)
                    {
                        bool isValid = coupon.ExpiryDate > DateTime.Now && coupon.UsageLimit > 0;
                        string cardClass = isValid ? "border-primary bg-white shadow-sm" : "border-secondary bg-light opacity-75";
                        string btnClass = isValid ? "btn-primary" : "btn-secondary disabled";
                        string discountText = coupon.DiscountPercentage.HasValue ? $"Giảm {coupon.DiscountPercentage.Value.ToString("0")} %" : $"Giảm {coupon.MaxDiscountAmount?.ToString("N0")} ₫";

                        <div class="card mb-3 @cardClass">
                            <div class="row g-0">
                                <div class="col-4 bg-primary text-white d-flex align-items-center justify-content-center flex-column p-2 rounded-start" style="@(!isValid ? "background-color: #6c757d !important;" : "")">
                                    <i class="fa-solid fa-gift fs-3 mb-1"></i>
                                    <span class="text-center fw-bold lh-sm" style="font-size:0.9em;">@discountText</span>
                                </div>
                                <div class="col-8">
                                    <div class="card-body p-2 d-flex flex-column justify-content-between h-100">
                                        <div>
                                            <h6 class="card-title mb-1 fw-bold">@coupon.CouponName</h6>
                                            <p class="card-text text-muted mb-0" style="font-size:0.8em;">Mã: <strong>@coupon.Code</strong></p>
                                            <p class="card-text text-muted mb-0" style="font-size:0.8em;">HSD: @coupon.ExpiryDate.ToString("dd/MM/yyyy")</p>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            @if (!isValid)
                                            {
                                                <span class="text-danger" style="font-size:0.75em;">Đã hết hạn/lượt</span>
                                            }
                                            else
                                            {
                                                <span class="text-success" style="font-size:0.75em;">Còn @coupon.UsageLimit lượt</span>
                                            }
                                            <button type="button" class="btn btn-sm @btnClass select-voucher-btn" data-code="@coupon.Code">Dùng ngay</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-4">Hiện tại không có mã khuyến mãi nào khả dụng.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Lấy dữ liệu cơ sở từ Model
            const initialTotalAmount = parseFloat('@String.Format("{0:0}", Model.TotalAmount)');
            var totalQuantityInCart = @(Model.CartItems?.Sum(i => i.Quantity) ?? 1);

            let currentShippingFee = 0;
            let currentVoucherDiscount = 0;

            function formatCurrency(amount) {
                return amount.toLocaleString('vi-VN', { style: 'currency', currency: 'VND', minimumFractionDigits: 0 });
            }

            function updateOrderSummary() {
                if (currentShippingFee > 0) {
                    $('#shippingFeeDisplay').text("+" + formatCurrency(currentShippingFee));
                    $('#shippingFeeLabel').text(formatCurrency(currentShippingFee));
                } else {
                    $('#shippingFeeDisplay').text('Đang chờ tính...');
                    $('#shippingFeeLabel').text('Chưa xác định');
                }

                let finalTotal = initialTotalAmount + currentShippingFee - currentVoucherDiscount;
                if (finalTotal < 0) finalTotal = 0;

                $('#finalTotalDisplay').text(formatCurrency(finalTotal));
                $('#TotalAmount').val(finalTotal);
            }

            function buildFullAddressString() {
                var street = $('#txtStreetAddress').val();
                var ward = $('#ddlWard option:selected').text();
                var district = $('#ddlDistrict option:selected').text();
                var province = $('#ddlProvince option:selected').text();

                if(street && $('#ddlWard').val()) {
                    var fullAddress = street + ", " + ward + ", " + district + ", " + province;
                    $('#shippingAddress').val(fullAddress);
                }
            }

            function validateAndPrepareSubmit() {
                var wardCode = $('#ddlWard').val();
                var street = $('#txtStreetAddress').val().trim(); // Lấy giá trị ô tên đường

                if (!wardCode) {
                    alert("Vui lòng chọn đầy đủ Tỉnh/Thành, Quận/Huyện và Phường/Xã!");
                    return false;
                }

                // --- BỔ SUNG ĐOẠN NÀY ---
                if (!street) {
                    alert("Vui lòng nhập Số nhà, tên đường cụ thể!");
                    $('#txtStreetAddress').focus(); // Tự động nháy chuột vào ô nhập
                    return false;
                }
                // ------------------------

                buildFullAddressString();

                // Kiểm tra lại lần cuối trước khi submit
                if (!$('#shippingAddress').val()) {
                    alert("Lỗi tạo địa chỉ, vui lòng kiểm tra lại thông tin!");
                    return false;
                }

                return true;
            }

            // HÀM XỬ LÝ LỖI TRẢ VỀ TỪ CONTROLLER SIÊU AN TOÀN
            function parseData(response) {
                if (!response) return [];
                if (response.error) {
                    console.error("Lỗi từ Server:", response.error);
                    return [];
                }
                try {
                    return typeof response === 'string' ? JSON.parse(response) : response;
                } catch (e) {
                    console.error("Lỗi parse JSON:", e);
                    return [];
                }
            }

            // HÀM DỌN RÁC "TEST-ALERT" VÀ "02" TỪ GHN
            function cleanName(name) {
                if (!name) return "";
                return name.replace(/^(0\d\s*|Test\s*-\s*Alert.*?\s*-\s*\d+\s*)/gi, '').trim();
            }

            // Mặc định chọn COD
            if (!$('input[name="PaymentMethod"]:checked').length) {
                $('#pay-cash').prop('checked', true);
            }

            // 1. TẢI TỈNH/THÀNH
            $.ajax({
                url: '@Url.Action("GetProvinces", "Orders")',
                type: 'GET',
                success: function (response) {
                    var data = parseData(response);
                    var ddlProvince = $('#ddlProvince');
                    $.each(data, function (index, item) {
                        ddlProvince.append($('<option>', {
                            value: item.ProvinceID,
                            text: cleanName(item.ProvinceName)
                        }));
                    });
                }
            });

            // 2. LOAD QUẬN/HUYỆN
            $('#ddlProvince').change(function () {
                var provinceId = $(this).val();
                var ddlDistrict = $('#ddlDistrict');
                var ddlWard = $('#ddlWard');

                ddlDistrict.empty().append('<option value="">-- Chọn Quận / Huyện --</option>').prop('disabled', true);
                ddlWard.empty().append('<option value="">-- Chọn Phường / Xã --</option>').prop('disabled', true);
                currentShippingFee = 0;
                updateOrderSummary();

                if (provinceId) {
                    $('#hdnProvinceId').val(provinceId);
                    $.ajax({
                        url: '@Url.Action("GetDistricts", "Orders")',
                        type: 'GET',
                        data: { provinceId: provinceId },
                        success: function (response) {
                            var data = parseData(response);
                            if (data.length > 0) {
                                $.each(data, function (index, item) {
                                    ddlDistrict.append($('<option>', {
                                        value: item.DistrictID,
                                        text: cleanName(item.DistrictName)
                                    }));
                                });
                                ddlDistrict.prop('disabled', false);
                            } else {
                                alert("Không thể tải Quận/Huyện. Vui lòng tải lại trang!");
                            }
                        }
                    });
                }
            });

            // 3. LOAD PHƯỜNG/XÃ
            $('#ddlDistrict').change(function () {
                var districtId = $(this).val();
                var ddlWard = $('#ddlWard');

                ddlWard.empty().append('<option value="">-- Chọn Phường / Xã --</option>').prop('disabled', true);
                currentShippingFee = 0;
                updateOrderSummary();

                if (districtId) {
                    $('#hdnDistrictId').val(districtId);
                    $.ajax({
                        url: '@Url.Action("GetWards", "Orders")',
                        type: 'GET',
                        data: { districtId: districtId },
                        success: function (response) {
                            var data = parseData(response);
                            if (data.length > 0) {
                                $.each(data, function (index, item) {
                                    ddlWard.append($('<option>', {
                                        value: item.WardCode,
                                        text: cleanName(item.WardName)
                                    }));
                                });
                                ddlWard.prop('disabled', false);
                            }
                        }
                    });
                }
            });

            // 4. TÍNH PHÍ VẬN CHUYỂN
            $('#ddlWard').change(function () {
                var wardCode = $(this).val();
                var districtId = $('#ddlDistrict').val();

                if (wardCode && districtId) {
                    $('#hdnWardCode').val(wardCode);
                    buildFullAddressString();

                    $('#shippingFeeDisplay').text('Đang tính...');

                    $.ajax({
                        url: '@Url.Action("CalculateShippingFee", "Orders")',
                        type: 'POST',
                        data: {
                            districtId: districtId,
                            wardCode: wardCode,
                            totalQuantity: totalQuantityInCart
                        },
                        success: function (res) {
                            if (res.success) {
                                currentShippingFee = res.fee;
                                updateOrderSummary();
                                $('#HiddenShippingFee').val(res.fee);
                            } else {
                                alert("Không thể lấy phí vận chuyển từ GHN: " + res.error);
                                currentShippingFee = 0;
                                updateOrderSummary();
                            }
                        }
                    });
                } else {
                    currentShippingFee = 0;
                    updateOrderSummary();
                }
            });

            // Cập nhật chuỗi địa chỉ khi gõ số nhà
            $('#txtStreetAddress').on('input', buildFullAddressString);

            // XỬ LÝ VOUCHER
            $(".select-voucher-btn").click(function () {
                if ($(this).hasClass("disabled")) return;

                var code = $(this).attr("data-code");
                var msgBox = $("#voucherMessage");

                var myModalEl = document.getElementById('voucherModal');
                var modal = bootstrap.Modal.getInstance(myModalEl);
                if(modal) modal.hide();

                $.ajax({
                    url: '@Url.Action("ApplyCoupon", "Cart")',
                    type: 'POST',
                    data: { couponCode: code },
                    success: function (res) {
                        if (res.success) {
                            msgBox.removeClass("text-danger").addClass("text-success").text("✅ Áp dụng mã " + code + " thành công!").show();
                            $("#selectedVoucherDisplay").html('<span class="fw-bold text-success">' + code + '</span>');

                            currentVoucherDiscount = res.discountAmount;
                            $("#AppliedVoucherCode").val(code);
                            $("#VoucherDiscount").val(res.discountAmount);

                            $("#voucherDiscountDisplay").text("-" + formatCurrency(res.discountAmount));
                            $("#voucherRow").slideDown();

                            updateOrderSummary();
                        } else {
                            msgBox.removeClass("text-success").addClass("text-danger").text("❌ " + res.message).show();
                            $("#selectedVoucherDisplay").html('<span class="text-danger">Mã không hợp lệ</span>');

                            currentVoucherDiscount = 0;
                            $("#AppliedVoucherCode").val("");
                            $("#VoucherDiscount").val(0);
                            $("#voucherRow").slideUp();

                            updateOrderSummary();
                        }
                    }
                });
            });

            // Khởi tạo hiển thị lần đầu
            updateOrderSummary();
        });
    </script>
}