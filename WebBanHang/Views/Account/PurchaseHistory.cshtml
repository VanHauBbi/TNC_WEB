@model IEnumerable<WebBanHang.Models.Order>
@{
    ViewBag.Title = "Lịch sử mua hàng";
    Layout = "~/Views/Shared/_LayoutDivMain.cshtml";
}

<link rel="stylesheet" href="~/Content/myStyle/purchasehistory.css" />

<div class="container my-5">
    <h2 class="mb-4">Lịch Sử Mua Hàng</h2>
    <p class="text-muted">Bạn có tổng cộng: <strong>@Model.Count() </strong> đơn hàng.</p>

    <table class="table table-bordered table-hover order-history-table">
        <thead class="table-primary text-center align-middle">
            <tr>
                <th>Mã ĐH</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái Đơn hàng</th>
                <th>Trạng thái Thanh toán</th>
                <th>Phương thức GH</th>
                <th>Chi tiết</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-secondary py-4">Bạn chưa có đơn hàng nào.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr class="text-center align-middle">
                    <td>#@item.OrderID</td>
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="fw-bold text-danger">@item.TotalAmount.ToString("N0") ₫</td>

                    <td>
                        @{
                            string orderStatus = string.IsNullOrEmpty(item.OrderStatus) ? "Chờ xác nhận" : item.OrderStatus;
                            string orderBadge = "badge bg-secondary"; // Mặc định: Chờ xác nhận

                            if (orderStatus == "Đã duyệt") { orderBadge = "badge bg-primary"; }
                            else if (orderStatus == "Đang giao") { orderBadge = "badge bg-info text-dark"; }
                            else if (orderStatus == "Đã giao") { orderBadge = "badge bg-success"; }
                            else if (orderStatus == "Đã hủy") { orderBadge = "badge bg-danger"; }
                        }
                        <span class="@orderBadge fs-6">@orderStatus</span>
                    </td>

                    <td>
                        @{
                            string payStatus = string.IsNullOrEmpty(item.PaymentStatus) ? "Chưa thanh toán" : item.PaymentStatus;
                            string payBadge = (payStatus == "Đã thanh toán") ? "badge bg-success" : "badge bg-warning text-dark";
                        }
                        <span class="@payBadge">@payStatus</span>
                    </td>

                    <td>@item.ShippingMethod</td>
                    <td>
                        @Html.ActionLink("Xem Chi Tiết", "Details", "Orders", new { id = item.OrderID }, new { @class = "btn btn-sm btn-info text-white" })
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        @Html.ActionLink("← Tiếp tục mua sắm", "Index", "Home", null, new { @class = "btn btn-outline-primary" })
    </div>
</div>