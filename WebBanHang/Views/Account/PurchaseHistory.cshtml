@model IEnumerable<WebBanHang.Models.Order>
@{
    ViewBag.Title = "Lịch sử mua hàng";
    Layout = "~/Views/Shared/_LayoutDivMain.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="~/Content/myStyle/purchasehistory.css" />

<div class="container my-5">
    <div class="purchase-history-page">

        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold mb-1 page-title-custom">Lịch Sử Mua Hàng</h2>
                <p class="text-muted mb-0"><i class="fas fa-box-open me-2"></i>Bạn có tổng cộng: <strong>@Model.Count()</strong> đơn hàng.</p>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="table table-hover order-history-table mb-0 text-center">
                <thead class="table-light text-muted border-bottom-0">
                    <tr class="align-middle">
                        <th class="py-3 fw-semibold"><i class="fas fa-hashtag me-1"></i> Mã ĐH</th>
                        <th class="py-3 fw-semibold"><i class="far fa-calendar-alt me-1"></i> Ngày đặt</th>
                        <th class="py-3 fw-semibold"><i class="fas fa-coins me-1"></i> Tổng tiền</th>
                        <th class="py-3 fw-semibold"><i class="fas fa-shipping-fast me-1"></i> Trạng thái</th>
                        <th class="py-3 fw-semibold"><i class="far fa-credit-card me-1"></i> Thanh toán</th>
                        <th class="py-3 fw-semibold"><i class="fas fa-truck me-1"></i> ĐV Vận chuyển</th>
                        <th class="py-3 fw-semibold">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-secondary py-5">
                                <i class="fas fa-box-open fa-3x mb-3 text-light"></i>
                                <br />Bạn chưa có đơn hàng nào.
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model.OrderBy(x => x.OrderID))
                    {
                        <!-- Căn giữa nội dung các hàng -->
                        <tr class="align-middle">
                            <td class="fw-bold text-order-id">#@item.OrderID</td>

                            <td class="text-muted">@item.OrderDate.ToString("dd/MM/yyyy - HH:mm")</td>

                            <td class="fw-bold text-danger">@item.TotalAmount.ToString("N0") ₫</td>

                            <td>
                                @{
                                    string orderStatus = string.IsNullOrEmpty(item.OrderStatus) ? "Chờ xác nhận" : item.OrderStatus;
                                    string orderBadge = "status-badge status-pending";

                                    if (orderStatus == "Đã duyệt") { orderBadge = "status-badge status-approved"; }
                                    else if (orderStatus == "Đang giao") { orderBadge = "status-badge status-shipping"; }
                                    else if (orderStatus == "Đã giao") { orderBadge = "status-badge status-delivered"; }
                                    else if (orderStatus == "Đã hủy") { orderBadge = "status-badge status-canceled"; }
                                }
                                <span class="@orderBadge">@orderStatus</span>
                            </td>

                            <td>
                                @{
                                    string payStatus = string.IsNullOrEmpty(item.PaymentStatus) ? "Chưa thanh toán" : item.PaymentStatus;
                                    string payBadge = (payStatus == "Đã thanh toán") ? "status-badge status-paid" : "status-badge status-unpaid";
                                }
                                <span class="@payBadge">@payStatus</span>
                            </td>

                            <td class="text-muted small">@item.ShippingMethod</td>
                            <td>
                               @Html.ActionLink("Chi Tiết", "Details", "Orders", new { id = item.OrderID }, new { @class = "btn-action" })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 text-start">
            @Html.ActionLink("← Tiếp tục mua sắm", "Index", "Home", null, new { @class = "btn px-4 rounded-pill btn-continue-shopping" })
        </div>
    </div>
</div>