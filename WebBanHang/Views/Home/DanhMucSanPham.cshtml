@using WebBanHang.Utilities
@using PagedList.Mvc;
@model PagedList.IPagedList<WebBanHang.Models.Product>
@{
    ViewBag.Title = ViewBag.CategoryName;
    Layout = "~/Views/Shared/_LayoutDivMain.cshtml";

    // Lấy các giá trị lọc hiện tại từ ViewBag
    int categoryId = (int)ViewBag.CategoryId;
    string currentPrice = ViewBag.CurrentPriceRange;
    string currentSort = ViewBag.CurrentSortBy;
}
<link rel="stylesheet" href="~/Content/myStyle/danhmucsanpham.css" />
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

<div class="container-fluid category-page-wrapper mt-3">

    <h2 class="category-title mb-4">@ViewBag.CategoryName</h2>

    <div class="row">

        <div class="col-lg-3 col-md-4 mb-4">
            <div class="filter-sidebar">
                <h4 class="sidebar-title">Lọc sản phẩm</h4>

                <div class="filter-group">
                    <p class="filter-heading">Theo Khoảng Giá</p>
                    <ul class="list-unstyled filter-options">
                        <li class="@(string.IsNullOrEmpty(currentPrice) ? "active" : "")">
                            <a href="@Url.Action("DanhMucSanPham", new { id = categoryId, priceRange = "", sortBy = currentSort })">Tất cả</a>
                        </li>
                        <li class="@(currentPrice == "duoi-5" ? "active" : "")">
                            <a href="@Url.Action("DanhMucSanPham", new { id = categoryId, priceRange = "duoi-5", sortBy = currentSort })">Dưới 5 triệu</a>
                        </li>
                        <li class="@(currentPrice == "5-10" ? "active" : "")">
                            <a href="@Url.Action("DanhMucSanPham", new { id = categoryId, priceRange = "5-10", sortBy = currentSort })">Từ 5 - 10 triệu</a>
                        </li>
                        <li class="@(currentPrice == "tren-10" ? "active" : "")">
                            <a href="@Url.Action("DanhMucSanPham", new { id = categoryId, priceRange = "tren-10", sortBy = currentSort })">Trên 10 triệu</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">

            <div class="sort-bar d-flex justify-content-end align-items-center mb-3 p-2 bg-light rounded">
                <span class="text-muted me-2">Sắp xếp theo:</span>
                <select class="form-select sort-select" id="sortSelect">
                    <option value="default" @(string.IsNullOrEmpty(currentSort) ? "selected" : "")>Mới nhất</option>
                    <option value="price-asc" @(currentSort == "price-asc" ? "selected" : "")>Giá: Thấp đến Cao</option>
                    <option value="price-desc" @(currentSort == "price-desc" ? "selected" : "")>Giá: Cao đến Thấp</option>
                    <option value="name-asc" @(currentSort == "name-asc" ? "selected" : "")>Tên: A-Z</option>
                    <option value="name-desc" @(currentSort == "name-desc" ? "selected" : "")>Tên: Z-A</option>
                </select>
            </div>

            <div class="row product-grid">
                @foreach (var p in Model)
                {
                    <div class="col-xl-4 col-lg-6 col-md-12 col-sm-6 mb-4">
                        <div class="card product-card h-100 shadow-sm" style="border-radius: 12px; overflow: hidden; border: 1px solid #eee;">
                            <a href="@Url.Action("ProductDetail", "Home", new { id = p.ProductID })" class="product-link text-center p-3">
                                <img src="@Url.Content(p.ProductImage)" class="card-img-top product-image-list" alt="@p.ProductName" style="object-fit: contain; height: 180px; width: 100%;" />
                            </a>
                            <div class="card-body d-flex flex-column" style="padding: 15px 20px 20px 20px;">
                                <h5 class="card-title product-name-list" style="font-size: 0.95rem; font-weight: 600; height: 42px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; line-height: 1.4;">
                                    <a href="@Url.Action("ProductDetail", "Home", new { id = p.ProductID })" class="text-dark text-decoration-none">@p.ProductName</a>
                                </h5>
                                @{
                                    decimal discountPercent;
                                    decimal discountedPrice = PriceHelper.GetDiscountedPrice(p, out discountPercent);
                                    bool isDiscounted = discountedPrice < p.ProductPrice;

                                    // Lấy trạng thái sản phẩm
                                    string cardState = p.GetStatusLabel();
                                }
                                <div class="card-text mt-auto mb-3">
                                    @if (p.ProductPrice <= 0)
                                    {
                                        <span class="fw-bold" style="color: #e6a23c; font-size:1.05rem;">Giá: Đang cập nhật</span>
                                    }
                                    else if (isDiscounted)
                                    {
                                        <span class="text-muted text-decoration-line-through me-2" style="font-size:0.85rem;">@p.ProductPrice.ToString("N0") đ</span>
                                        <span class="badge bg-danger px-1" style="font-size:0.75rem;">-@discountPercent.ToString("0")%</span>
                                        <br />
                                        <span class="text-danger fw-bold" style="font-size:1.15rem;">@discountedPrice.ToString("N0") đ</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold" style="font-size:1.15rem;">@p.ProductPrice.ToString("N0") đ</span>
                                    }
                                </div>

                                @if (cardState == "AVAILABLE")
                                {
                                    <button class="btn btn-outline-primary w-100 add-to-cart-btn" data-product-id="@p.ProductID" style="border-radius: 8px; font-weight: 500;">
                                        <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                }
                                else if (cardState == "OUT_OF_STOCK")
                                {
                                    <button type="button" class="btn btn-secondary w-100" disabled style="border-radius: 8px; font-weight: 500;">Hết hàng</button>
                                }
                                else if (cardState == "COMING_SOON")
                                {
                                    <button type="button" class="btn w-100" disabled style="background-color: #ffc107; color: #212529; border: none; border-radius: 8px; font-weight: 600;">Hàng sắp về</button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-outline-danger w-100" disabled style="border-radius: 8px; font-weight: 500;">Ngừng bán</button>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (!Model.Any())
                {
                    <div class="col-12">
                        <div class="alert alert-warning text-center" role="alert">
                            Không tìm thấy sản phẩm nào phù hợp với tiêu chí lọc.
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-center mt-5">
                @Html.PagedListPager(Model,
                    page => Url.Action("DanhMucSanPham",
                        new
                        {
                            id = categoryId,
                            page,
                            priceRange = currentPrice,
                            sortBy = currentSort
                        }),
                    new PagedListRenderOptions
                    {
                        ContainerDivClasses = new[] { "pagination" },
                        LiElementClasses = new[] { "page-item" }
                    })
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // === JAVASCRIPT CHO SẮP XẾP ===
            $('#sortSelect').on('change', function () {
                var selectedSort = $(this).val();
                var url = new URL(window.location.href);
                url.searchParams.set('sortBy', selectedSort);
                url.searchParams.set('page', '1');
                window.location.href = url.href;
            });

            // Nút "Thêm vào giỏ"
            $('.add-to-cart-btn').on('click', function () {
                var productId = $(this).data('product-id');
                if (typeof addToCart === 'function') {
                    addToCart(productId, 1);
                } else {
                    console.error("Hàm addToCart() không tồn tại.");
                }
            });

            // Sửa lỗi hiển thị Phân trang
            $('.pagination .page-item a').addClass('page-link');
            $('.pagination .page-item span').addClass('page-link');
        });
    </script>
}