@using WebBanHang.Utilities
@model WebBanHang.Models.ViewModel.HomeProductVM
@{
    ViewBag.Title = "Trang chủ - TNCStore";
    Layout = "~/Views/Shared/_LayoutDivMain.cshtml";
}

<link rel="stylesheet" href="~/Content/myStyle/home.css" />
<link href="~/Content/myStyle/chatbot.css" rel="stylesheet" />

<div class="container mt-4">

    <div class="row mb-5">
        <div class="col-12">
            <div id="mainBannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
                <div class="carousel-inner banner-carousel-inner rounded shadow-sm">
                    <div class="carousel-item active">
                        <img src="~/image/banner-haloween-pc-1.jpg" class="d-block w-100 banner-img-fit" alt="Khuyến mãi Halloween PC 1">
                    </div>
                    <div class="carousel-item">
                        <img src="~/image/banner-haloween-pc-2.jpg" class="d-block w-100 banner-img-fit" alt="Khuyến mãi Halloween PC 2">
                    </div>
                    <div class="carousel-item">
                        <img src="~/image/banner-trang-chu-pc-hoan-tien-4-phan-tram-1.jpg" class="d-block w-100 banner-img-fit" alt="Bảo hành đổi mới 3 năm">
                    </div>
                    <div class="carousel-item">
                        <img src="~/image/banner-mua-man-hinh-tang-tien-mat.jpg" class="d-block w-100 banner-img-fit" alt="Mua màn hình tặng tiền mặt">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#mainBannerCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#mainBannerCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </div>

    <div class="row mt-3 justify-content-center thumbnail-indicators">
        @{
            var bannerThumbnails = new List<string> {
                "banner-haloween-pc-1.jpg", "banner-haloween-pc-2.jpg",
                "banner-trang-chu-pc-hoan-tien-4-phan-tram-1.jpg", "banner-mua-man-hinh-tang-tien-mat.jpg"
            };
            int thumbnailIndex = 0;
        }
        @foreach (var bannerName in bannerThumbnails)
        {
            <div class="col-3 col-md-3 col-lg-2 p-1">
                <img src="~/image/@bannerName"
                     class="img-fluid banner-thumbnail-item rounded shadow-sm @(thumbnailIndex == 0 ? "active" : "")"
                     data-bs-target="#mainBannerCarousel" data-bs-slide-to="@thumbnailIndex" alt="Thumbnail @(thumbnailIndex + 1)" />
            </div>
            thumbnailIndex++;
        }
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2 mt-5 pt-5">
        <h3 class="fw-bold text-uppercase mb-0 text-primary"><i class="fa-solid fa-fire text-danger"></i> Sản phẩm nổi bật</h3>
    </div>

    <div class="row" id="featured-products-container">
        @{
            int featuredDisplayCount = 4;
            int featuredTotalCount = Model.FeaturedProducts.Count();
            int featuredProductIndex = 0;
        }

        @foreach (var item in Model.FeaturedProducts)
        {
            string featState = item.GetStatusLabel();
            string displayClass = (featuredProductIndex >= featuredDisplayCount) ? "d-none extra-featured-product" : "";
            decimal discountPercent;
            decimal discountedPrice = PriceHelper.GetDiscountedPrice(item, out discountPercent);
            bool isDiscounted = (discountedPrice < item.ProductPrice && featState == "AVAILABLE" && item.ProductPrice > 0);

            <div class="col-xl-3 col-lg-4 col-md-6 col-6 mb-4 @displayClass">
                <div class="card product-card-modern h-100 border-0 shadow-sm">
                    <div class="position-relative overflow-hidden product-img-wrapper">
                        @if (isDiscounted)
                        {
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-1 shadow-sm">-@discountPercent.ToString("0")%</span>
                        }
                        <a href="@Url.Action("ProductDetail", "Home", new { id = item.ProductID })">
                            <img src="@item.ProductImage" class="card-img-top p-3" alt="@item.ProductName" />
                        </a>
                    </div>

                    <div class="card-body d-flex flex-column px-3 pt-0 pb-3">
                        <a href="@Url.Action("ProductDetail", "Home", new { id = item.ProductID })" class="text-decoration-none">
                            <h6 class="card-title product-title-modern text-dark mb-2">@item.ProductName</h6>
                        </a>

                        <div class="price-area mt-auto">
                            @if (featState == "COMING_SOON")
                            {
                                <div class="text-warning fw-bold fs-6 mt-3">Giá: Đang cập nhật</div>
                            }
                            else if (isDiscounted)
                            {
                                <div class="text-muted text-decoration-line-through small">@item.ProductPrice.ToString("N0") ₫</div>
                                <div class="text-danger fw-bold fs-5">@discountedPrice.ToString("N0") ₫</div>
                            }
                            else
                            {
                                <div class="text-danger fw-bold fs-5 mt-3">@item.ProductPrice.ToString("N0") ₫</div>
                            }
                        </div>

                        <div class="action-zone mt-3">
                            @if (featState == "AVAILABLE")
                            {
                                <button class="btn btn-outline-primary w-100 add-to-cart-btn fw-bold btn-cart-modern" data-product-id="@item.ProductID">
                                    <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                                </button>
                            }
                            else if (featState == "OUT_OF_STOCK")
                            {
                                <span class="badge bg-secondary w-100 py-2 d-block text-center">Tạm hết hàng</span>
                            }
                            else if (featState == "COMING_SOON")
                            {
                                <span class="badge bg-warning text-dark w-100 py-2 d-block text-center fw-bold">Hàng sắp về</span>
                            }
                            else
                            {
                                <span class="badge bg-danger w-100 py-2 d-block text-center">Ngừng bán</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            featuredProductIndex++;
        }
    </div>

    @if (featuredTotalCount > featuredDisplayCount)
    {
        <div class="text-center mb-5">
            <button class="btn btn-light border shadow-sm px-5 fw-bold text-primary btn-hover-scale" id="toggleFeaturedProducts" data-target="#featured-products-container">Xem thêm sản phẩm <i class="fa-solid fa-angle-down"></i></button>
        </div>
    }

    <div id="khuyen-mai-section" class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2 mt-5 pt-5">
        <h3 class="fw-bold text-uppercase mb-0" style="color: #e44d26;"><i class="fa-solid fa-tags"></i> Đang Giảm Giá Kho Sốc</h3>
    </div>

    <div class="row">
        @{
            var saleProducts = new List<WebBanHang.Models.Product>();
            var allProducts = Model.FeaturedProducts.Concat(Model.NewProducts).GroupBy(p => p.ProductID).Select(g => g.First());

            foreach (var item in allProducts)
            {
                if (item.GetStatusLabel() == "AVAILABLE" && item.ProductPrice > 0)
                {
                    decimal tempPercent;
                    if (PriceHelper.GetDiscountedPrice(item, out tempPercent) < item.ProductPrice)
                    {
                        saleProducts.Add(item);
                    }
                }
            }
        }

        @if (!saleProducts.Any())
        {
            <div class="col-12"><p class="text-muted text-center py-4">Hiện tại không có chương trình khuyến mãi nào.</p></div>
        }
        else
        {
            foreach (var item in saleProducts.Take(4))
            {
                decimal discountPercent;
                decimal discountedPrice = PriceHelper.GetDiscountedPrice(item, out discountPercent);

                <div class="col-xl-3 col-lg-4 col-md-6 col-6 mb-4">
                    <div class="card product-card-modern h-100 border-0 shadow-sm" style="border: 2px solid #ffeeba !important;">
                        <div class="position-relative overflow-hidden product-img-wrapper">
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-1 shadow-sm fs-6">-@discountPercent.ToString("0")%</span>
                            <a href="@Url.Action("ProductDetail", "Home", new { id = item.ProductID })">
                                <img src="@item.ProductImage" class="card-img-top p-3" alt="@item.ProductName" />
                            </a>
                        </div>

                        <div class="card-body d-flex flex-column px-3 pt-0 pb-3">
                            <a href="@Url.Action("ProductDetail", "Home", new { id = item.ProductID })" class="text-decoration-none">
                                <h6 class="card-title product-title-modern text-dark mb-2">@item.ProductName</h6>
                            </a>

                            <div class="price-area mt-auto">
                                <div class="text-muted text-decoration-line-through small">@item.ProductPrice.ToString("N0") ₫</div>
                                <div class="text-danger fw-bold fs-5">@discountedPrice.ToString("N0") ₫</div>
                            </div>

                            <button class="btn btn-danger w-100 mt-3 add-to-cart-btn fw-bold btn-cart-modern" data-product-id="@item.ProductID">
                                Mua Ngay Kẻo Lỡ
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2 mt-5">
        <h3 class="fw-bold text-uppercase mb-0 text-success"><i class="fa-solid fa-bolt text-warning"></i> Sản phẩm mới về</h3>
    </div>

    <div class="row" id="new-products-container">
        @{
            int newDisplayCount = 4;
            int newTotalCount = Model.NewProducts.Count();
            int newProductIndex = 0;
        }

        @foreach (var item in Model.NewProducts)
        {
            string newState = item.GetStatusLabel();
            string displayClass = (newProductIndex >= newDisplayCount) ? "d-none extra-new-product" : "";
            decimal discountPercent;
            decimal discountedPrice = PriceHelper.GetDiscountedPrice(item, out discountPercent);
            bool isDiscounted = (discountedPrice < item.ProductPrice && newState == "AVAILABLE" && item.ProductPrice > 0);

            <div class="col-xl-3 col-lg-4 col-md-6 col-6 mb-4 @displayClass">
                <div class="card product-card-modern h-100 border-0 shadow-sm">
                    <div class="position-relative overflow-hidden product-img-wrapper">
                        <span class="badge bg-success position-absolute top-0 end-0 m-2 z-1 shadow-sm">MỚI</span>
                        @if (isDiscounted)
                        {
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-1 shadow-sm">-@discountPercent.ToString("0")%</span>
                        }
                        <a href="@Url.Action("ProductDetail", "Home", new { id = item.ProductID })">
                            <img src="@item.ProductImage" class="card-img-top p-3" alt="@item.ProductName" />
                        </a>
                    </div>

                    <div class="card-body d-flex flex-column px-3 pt-0 pb-3">
                        <a href="@Url.Action("ProductDetail", "Home", new { id = item.ProductID })" class="text-decoration-none">
                            <h6 class="card-title product-title-modern text-dark mb-2">@item.ProductName</h6>
                        </a>

                        <div class="price-area mt-auto">
                            @if (newState == "COMING_SOON")
                            {
                                <div class="text-warning fw-bold fs-6 mt-3">Giá: Đang cập nhật</div>
                            }
                            else if (isDiscounted)
                            {
                                <div class="text-muted text-decoration-line-through small">@item.ProductPrice.ToString("N0") ₫</div>
                                <div class="text-danger fw-bold fs-5">@discountedPrice.ToString("N0") ₫</div>
                            }
                            else
                            {
                                <div class="text-danger fw-bold fs-5 mt-3">@item.ProductPrice.ToString("N0") ₫</div>
                            }
                        </div>

                        <div class="action-zone mt-3">
                            @if (newState == "AVAILABLE")
                            {
                                <button class="btn btn-outline-success w-100 add-to-cart-btn fw-bold btn-cart-modern" data-product-id="@item.ProductID">
                                    <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                                </button>
                            }
                            else if (newState == "OUT_OF_STOCK")
                            {
                                <span class="badge bg-secondary w-100 py-2 d-block text-center">Tạm hết hàng</span>
                            }
                            else if (newState == "COMING_SOON")
                            {
                                <span class="badge bg-warning text-dark w-100 py-2 d-block text-center fw-bold">Hàng sắp về</span>
                            }
                            else
                            {
                                <span class="badge bg-danger w-100 py-2 d-block text-center">Ngừng bán</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            newProductIndex++;
        }
    </div>

    @if (newTotalCount > newDisplayCount)
    {
        <div class="text-center mb-5">
            <button class="btn btn-light border shadow-sm px-5 fw-bold text-success btn-hover-scale" id="toggleNewProducts" data-target="#new-products-container">Xem thêm sản phẩm <i class="fa-solid fa-angle-down"></i></button>
        </div>
    }

</div>

@section Scripts {
    <script>
        function setupProductToggle(buttonId, productClass) {
            const toggleBtn = document.getElementById(buttonId);
            if (!toggleBtn) return;

            const productContainers = document.querySelectorAll(productClass);
            let showAll = false;

            toggleBtn.addEventListener("click", function () {
                showAll = !showAll;

                productContainers.forEach(p => {
                    if (showAll) {
                        p.classList.remove('d-none');
                        p.style.display = '';
                    } else {
                        p.classList.add('d-none');
                    }
                });

                toggleBtn.innerHTML = showAll ? 'Thu gọn <i class="fa-solid fa-angle-up"></i>' : 'Xem thêm sản phẩm <i class="fa-solid fa-angle-down"></i>';
            });
        }

        setupProductToggle("toggleNewProducts", ".extra-new-product");
        setupProductToggle("toggleFeaturedProducts", ".extra-featured-product");

        document.querySelectorAll(".add-to-cart-btn").forEach(button => {
            button.addEventListener("click", function () {
                const productId = this.getAttribute("data-product-id");
                if (typeof addToCart === 'function') {
                    addToCart(productId, 1);
                } else {
                    alert("Chức năng thêm vào giỏ hàng chưa được kích hoạt!");
                }
            });
        });
    </script>
}