@using PagedList.Mvc
@model WebBanHang.Models.ViewModel.ProductDetailsVM

@if (Model.TopProduct != null && Model.TopProduct.Any())
{
    <div class="top-products-grid">
        @foreach (var product in Model.TopProduct)
        {
            <div class="product-card">
                <a href="@Url.Action("ProductDetail", "Home", new { id = product.ProductID })" class="product-card-link">
                    <img src="@product.ProductImage" alt="@product.ProductName" class="product-card-image" />
                </a>

                <div class="product-card-info">
                    <h5 class="product-card-name">
                        <a href="@Url.Action("ProductDetail", "Home", new { id = product.ProductID })" title="@product.ProductName">
                            @product.ProductName
                        </a>
                    </h5>

                    <p class="product-card-price">
                        @product.ProductPrice.ToString("N0") VNĐ
                    </p>

                    @{ string topCardState = product.GetStatusLabel(); }

                    @if (topCardState == "AVAILABLE")
                    {
                        <button type="button" class="btn-card-add-to-cart" data-product-id="@product.ProductID" onclick="addToCartFromCard(@product.ProductID)">
                            <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                        </button>
                    }
                    else if (topCardState == "OUT_OF_STOCK")
                    {
                        <button type="button" class="btn btn-secondary btn-sm w-100 mt-2" disabled style="font-size:12px;">Hết hàng</button>
                    }
                    else if (topCardState == "COMING_SOON")
                    {
                        <button type="button" class="btn btn-warning btn-sm w-100 mt-2 text-dark fw-bold" disabled style="font-size:12px;">Sắp về</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-danger btn-sm w-100 mt-2" disabled style="font-size:12px;">Ngừng bán</button>
                    }
                </div>
            </div>
        }
    </div>

    <div class="pagination-container mt-4">
        @Html.PagedListPager(Model.TopProduct, page => Url.Action("ProductDetail", "Home", new { id = Model.product.ProductID, quantity = Model.quantity, page }),
            new PagedListRenderOptions
                 {
                UlElementClasses = new[] { "pagination", "justify-content-center" },
                LiElementClasses = new[] { "page-item" },
                LinkToFirstPageFormat = "<i class='fas fa-angle-double-left'></i>",
                LinkToPreviousPageFormat = "<i class='fas fa-angle-left'></i>",
                LinkToNextPageFormat = "<i class='fas fa-angle-right'></i>",
                LinkToLastPageFormat = "<i class='fas fa-angle-double-right'></i>",
                Display = PagedListDisplayMode.IfNeeded
            })
    </div>

    <script>
        function addToCartFromCard(productId) {
            if (typeof jQuery == 'undefined') return;
            $.ajax({
                url: '@Url.Action("AddToCart", "Cart")',
                type: 'POST',
                data: { id: productId, quantity: 1 },
                success: function (response) {
                    if (response.success) {
                        alert("✅ Đã thêm sản phẩm vào giỏ!");
                        if (typeof MiniCart === "function") MiniCart();
                    } else { alert(response.message || "❌ Lỗi thao tác!"); }
                }
            });
        }
    </script>
}