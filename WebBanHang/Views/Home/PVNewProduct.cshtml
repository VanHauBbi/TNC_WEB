@using WebBanHang.Utilities
@model WebBanHang.Models.ViewModel.HomeProductVM
@using PagedList.Mvc

<link href="~/Content/myStyle/stylE.css" rel="stylesheet" />

@if (Model.NewProducts != null && Model.NewProducts.Any())
{
    <section class="container-fluid ListProduct">
        <h2>Sản phẩm mới</h2>

        <div class="feature-container">
            @foreach (var product in Model.NewProducts)
            {
                <div class="lproduct-item">
                    <div>
                        <a href="@Url.Action("ProductDetail", "Home", new { id = product.ProductID })">
                            <img src="@product.ProductImage" />
                        </a>
                    </div>
                    <div>
                        @* --- BẮT ĐẦU KHỐI GỌI HÀM TÍNH GIÁ ĐỘNG --- *@
                        @{
                            decimal discountPercent;
                            decimal discountedPrice = PriceHelper.GetDiscountedPrice(product, out discountPercent);
                            bool isDiscounted = discountedPrice < product.ProductPrice;
                        }

                        <div class="prodPrice" style="line-height: 1.2; margin-bottom: 8px;">
                            @if (isDiscounted)
                            {
                                <span class="text-muted text-decoration-line-through me-1" style="font-size:0.85em; color: #888;">@product.ProductPrice.ToString("N0") ₫</span>
                                <span class="badge bg-warning text-danger px-1" style="background-color: #ffc107; color: #dc3545; font-size:0.75em; border-radius: 3px;">-@discountPercent.ToString("0")%</span>
                                <br />
                                <span class="text-danger fw-bold" style="font-size:1.15em; color: #dc3545;">@discountedPrice.ToString("N0") ₫</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold" style="font-size:1.15em; color: #dc3545;">@product.ProductPrice.ToString("N0") ₫</span>
                            }
                        </div>
                        @* --- KẾT THÚC KHỐI GIÁ --- *@

                        <div class="prodName">
                            @product.ProductName
                        </div>
                        <p class="prodSale">
                            Đã bán: &nbsp; @product.OrderDetails.Count
                        </p>
                    </div>
                </div>
            }
        </div>
    </section>

    <div class="pagination-container">
        @Html.PagedListPager(Model.Products, page => @Url.Action("Index", new { page, searchTerm = Model.SearchTerm }))
    </div>
}
else
{
    <p>Không tìm được sản phẩm phù hợp</p>
}